// ==== Z-SCORE NORMALIZATION ====

// Calculate Z-score (standard score)
// @param value Current value
// @param length Lookback length for mean/stdev
// @returns Z-score normalized value
z(float value, int length) =>
    float mean = ta.sma(value, length)
    float stdDev = ta.stdev(value, length)
    stdDev > 0 ? (value - mean) / stdDev : 0.0

// Calculate Z-score with custom series for mean/stdev
// @param value Current value
// @param series Series to calculate stats from
// @param length Lookback length
// @returns Z-score normalized value
zCustom(float value, series float series, int length) =>
    float mean = ta.sma(series, length)
    float stdDev = ta.stdev(series, length)
    stdDev > 0 ? (value - mean) / stdDev : 0.0

// ==== RANGE NORMALIZATION ====

// Normalize value to 0-100 range
// @param value Current value
// @param length Lookback length for min/max
// @returns Normalized value (0-100)
normalize100(float value, int length) =>
    float highest = ta.highest(value, length)
    float lowest = ta.lowest(value, length)
    float span = highest - lowest
    span > 0 ? ((value - lowest) / span) * 100 : 50.0

// Normalize value to 0-1 range
// @param value Current value
// @param length Lookback length for min/max
// @returns Normalized value (0-1)
normalize01(float value, int length) =>
    normalize100(value, length) / 100.0

// ==== INTERPOLATION ====

// Linear interpolation
// @param t Interpolation factor (0-1)
// @param start Start value
// @param end End value
// @returns Interpolated value
lerp(float t, float start, float end) =>
    start + (t * (end - start))

// Inverse linear interpolation
// @param value Current value
// @param start Start value
// @param end End value
// @returns Interpolation factor (0-1)
inverseLerp(float value, float start, float end) =>
    float span = end - start
    span != 0 ? (value - start) / span : 0.0

// Normalize value to custom range
// @param value Current value
// @param length Lookback length
// @param min Target minimum
// @param max Target maximum
// @returns Normalized value in custom range
normalizeRange(float value, int length, float min, float max) =>
    float normalized01 = normalize01(value, length)
    lerp(normalized01, min, max)

// ==== ATR UTILITIES ====

// Calculate ATR as percentage of price
// @param atr ATR value
// @param price Current price
// @returns ATR percentage
atrPercent(float atr, float price) =>
    price > 0 ? (atr / price) * 100 : 0.0

// Calculate ATR multiple
// @param distance Price distance
// @param atr ATR value
// @returns Distance in ATR multiples
atrMultiple(float distance, float atr) =>
    atr > 0 ? math.abs(distance) / atr : 0.0

// ==== SMOOTHING ====

// Smooth series with EMA
// @param series Input series
// @param length Smoothing length
// @returns Smoothed series
smooth(series float series, int length) =>
    ta.ema(series, length)

// Smooth series with SMA
// @param series Input series
// @param length Smoothing length
// @returns Smoothed series
smoothSMA(series float series, int length) =>
    ta.sma(series, length)

// Smooth series with WMA
// @param series Input series
// @param length Smoothing length
// @returns Smoothed series
smoothWMA(series float series, int length) =>
    ta.wma(series, length)

// Double smoothing (EMA of EMA)
// @param series Input series
// @param length Smoothing length
// @returns Double smoothed series
doubleSmooth(series float series, int length) =>
    ta.ema(ta.ema(series, length), length)

// ==== CLAMPING & LIMITING ====

// Clamp value between min and max
// @param value Input value
// @param min Minimum value
// @param max Maximum value
// @returns Clamped value
clamp(float value, float min, float max) =>
    math.max(min, math.min(max, value))

// Clamp to 0-100 range
// @param value Input value
// @returns Clamped value (0-100)
clamp100(float value) =>
    clamp(value, 0.0, 100.0)

// Clamp to 0-1 range
// @param value Input value
// @returns Clamped value (0-1)
clamp01(float value) =>
    clamp(value, 0.0, 1.0)

// Clamp to -1 to +1 range
// @param value Input value
// @returns Clamped value (-1 to +1)
clampPlusMinus1(float value) =>
    clamp(value, -1.0, 1.0)

// Map value from one range to another
// @param value Input value
// @param inMin Input range min
// @param inMax Input range max
// @param outMin Output range min
// @param outMax Output range max
// @returns Mapped value
mapRange(float value, float inMin, float inMax, float outMin, float outMax) =>
    float t = inverseLerp(value, inMin, inMax)
    lerp(t, outMin, outMax)

// ==== AVERAGING ====

// Calculate weighted average
// @param value1 First value
// @param weight1 First weight
// @param value2 Second value
// @param weight2 Second weight
// @returns Weighted average
weightedAverage2(float value1, float weight1, float value2, float weight2) =>
    float totalWeight = weight1 + weight2
    totalWeight > 0 ? (value1 * weight1 + value2 * weight2) / totalWeight : 0.0

// Calculate weighted average of 3 values
// @param value1 First value
// @param weight1 First weight
// @param value2 Second value
// @param weight2 Second weight
// @param value3 Third value
// @param weight3 Third weight
// @returns Weighted average
weightedAverage3(float value1, float weight1, float value2, float weight2, float value3, float weight3) =>
    float totalWeight = weight1 + weight2 + weight3
    totalWeight > 0 ? (value1 * weight1 + value2 * weight2 + value3 * weight3) / totalWeight : 0.0

// Calculate weighted MTF strength (entry/bias/trend)
// @param entryScore Entry timeframe score
// @param biasScore Chart bias score
// @param trendScore Higher TF trend score
// @param wEntry Weight for entry score
// @param wBias Weight for bias score
// @param wTrend Weight for trend score
// @returns Weighted strength score
calculateMTFStrength(float entryScore, float biasScore, float trendScore, float wEntry, float wBias, float wTrend) =>
    float totalWeight = math.max(wEntry + wBias + wTrend, 0.0001)
    (entryScore * wEntry + biasScore * wBias + trendScore * wTrend) / totalWeight

// Trend support helpers for MTF hierarchy
// @param trendScore Trend score (-100..+100)
// @param threshold Required magnitude to confirm trend
// @returns true if trend supports long/short direction
trendSupportsLong(float trendScore, float threshold) =>
    trendScore >= threshold

trendSupportsShort(float trendScore, float threshold) =>
    trendScore <= -threshold

// Calculate geometric mean
// @param value1 First value
// @param value2 Second value
// @returns Geometric mean
geometricMean(float value1, float value2) =>
    value1 > 0 and value2 > 0 ? math.sqrt(value1 * value2) : 0.0

// ==== SCORING UTILITIES ====

// Convert percentage to score (-10 to +10)
// @param percent Percentage value (0-100)
// @returns Score (-10 to +10)
percentToScore(float percent) =>
    mapRange(percent, 0.0, 100.0, -10.0, 10.0)

// Convert score to percentage (0-100)
// @param score Score (-10 to +10)
// @returns Percentage (0-100)
scoreToPercent(float score) =>
    mapRange(score, -10.0, 10.0, 0.0, 100.0)

// Convert score to 0-1 range
// @param score Score (-10 to +10)
// @returns Normalized score (0-1)
scoreToNormalized(float score) =>
    scoreToPercent(score) / 100.0

// ==== RATE OF CHANGE ====

// Calculate rate of change
// @param series Input series
// @param length Lookback length
// @returns Rate of change
roc(series float series, int length) =>
    length > 0 ? ta.change(series, length) : 0.0

// Calculate percentage rate of change
// @param series Input series
// @param length Lookback length
// @returns Percentage ROC
rocPercent(series float series, int length) =>
    float past = series[length]
    past != 0 ? ((series - past) / past) * 100 : 0.0

// Calculate slope
// @param series Input series
// @param length Lookback length
// @returns Slope (per bar)
slope(series float series, int length) =>
    length > 0 ? roc(series, length) / length : 0.0

// ==== COMPARISON ====

// Check if value is near zero
// @param value Input value
// @param threshold Threshold for "near zero"
// @returns True if near zero
isNearZero(float value, float threshold = 0.01) =>
    math.abs(value) < threshold

// Check if values are approximately equal
// @param value1 First value
// @param value2 Second value
// @param tolerance Tolerance
// @returns True if approximately equal
isApproxEqual(float value1, float value2, float tolerance = 0.01) =>
    math.abs(value1 - value2) < tolerance

// Sign function
// @param value Input value
// @returns 1 for positive, -1 for negative, 0 for zero
sign(float value) =>
    value > 0 ? 1 : value < 0 ? -1 : 0

// ==== OSCILLATOR UTILITIES ====

// Normalize oscillator to -1 to +1 range
// @param value Oscillator value
// @param overbought Overbought level
// @param oversold Oversold level
// @returns Normalized oscillator (-1 to +1)
normalizeOscillator(float value, float overbought, float oversold) =>
    float mid = (overbought + oversold) / 2
    float span = (overbought - oversold) / 2
    span > 0 ? (value - mid) / span : 0.0

// Convert RSI to -1 to +1 range
// @param rsi RSI value (0-100)
// @returns Normalized RSI (-1 to +1)
normalizeRSI(float rsi) =>
    normalizeOscillator(rsi, 70.0, 30.0)

// Convert Stochastic to -1 to +1 range
// @param stoch Stochastic value (0-100)
// @returns Normalized Stochastic (-1 to +1)
normalizeStoch(float stoch) =>
    normalizeOscillator(stoch, 80.0, 20.0)

// ==== DISTANCE CALCULATIONS ====

// Calculate Euclidean distance between two points
// @param x1 First X coordinate
// @param y1 First Y coordinate
// @param x2 Second X coordinate
// @param y2 Second Y coordinate
// @returns Euclidean distance
distance2D(float x1, float y1, float x2, float y2) =>
    float dx = x2 - x1
    float dy = y2 - y1
    math.sqrt(dx * dx + dy * dy)

// Calculate Manhattan distance
// @param x1 First X coordinate
// @param y1 First Y coordinate
// @param x2 Second X coordinate
// @param y2 Second Y coordinate
// @returns Manhattan distance
manhattanDistance(float x1, float y1, float x2, float y2) =>
    math.abs(x2 - x1) + math.abs(y2 - y1)


