// ===========================================================================
// 4. VOLATILITY CONTEXT SCORE (0-1)
// ===========================================================================
// Favors acceleration/expansion phases (better trade environment)
// WCM REMOVED: Now using StochRSI + MACD for phase detection

// Helper: Calculate Market Phase from StochRSI + MACD (WCM replacement)
calculateMarketPhase(float stochRSI, float macdHist) =>
    // Phase detection using StochRSI (momentum) + MACD Histogram (trend acceleration)
    // StochRSI: 0-100 (overbought/oversold)
    // MACD Hist: positive = bullish, negative = bearish, magnitude = strength

    float stochNorm = (stochRSI - 50.0) / 50.0  // Convert to [-1, 1]
    float macdNormalized = macdHist  // Already directional

    // Combined momentum strength (both indicators agree)
    float momentumStrength = math.abs(stochNorm) * (stochNorm * macdNormalized > 0 ? 1.5 : 0.5)

    string phase = if momentumStrength >= 0.75
        "Acceleration"  // Extreme momentum, both agree
    else if momentumStrength >= 0.50
        "Expansion"     // Strong trend developing
    else if momentumStrength >= 0.25
        "Equilibrium"   // Moderate momentum
    else
        "Compression"   // Low momentum, consolidating

    phase

calculateVolatilityScore(float stochRSI, float macdHist, float atrCurrent, float atrAvg) =>
    // Guard against na values
    float _stochRSI = nz(stochRSI, 50.0)
    float _macdHist = nz(macdHist, 0.0)
    float _atrCurrent = nz(atrCurrent, 1.0)
    float _atrAvg = nz(atrAvg, 1.0)

    // Calculate phase using StochRSI + MACD
    string phase = calculateMarketPhase(_stochRSI, _macdHist)

    float phaseScore = 0.0

    // Phase scoring (same logic as WCM, but using StochRSI+MACD)
    if phase == "Acceleration"
        phaseScore := 1.0  // Best for entries - strong momentum
    else if phase == "Expansion"
        phaseScore := 0.8  // Good - expanding move
    else if phase == "Equilibrium"
        phaseScore := 0.5  // Neutral - balanced market
    else if phase == "Compression"
        phaseScore := 0.3  // Caution - consolidating
    else
        phaseScore := 0.5  // Unknown - default neutral

    // ATR context (prefer expanding volatility for breakouts)
    float atrRatio = _atrAvg > 0 ? _atrCurrent / _atrAvg : 1.0
    float atrScore = atrRatio > 1.2 ? 1.0 : atrRatio < 0.8 ? 0.3 : 0.6

    // Combine (70% phase, 30% ATR)
    (phaseScore * 0.7) + (atrScore * 0.3)

// ===========================================================================
// 5. CONFLUENCE SCORE (0-1)
// ===========================================================================
// Measures agreement between different indicator categories

calculateConfluenceScore(float flow, float mom, float trend, float vol, float structure, float div) =>
    // Guard against na values
    float _flow = nz(flow, 0.0)
    float _mom = nz(mom, 0.0)
    float _trend = nz(trend, 0.0)
    float _vol = nz(vol, 0.0)
    float _structure = nz(structure, 0.0)
    float _div = nz(div, 0.0)

    // Check if major categories agree
    bool flowTrendAgree = (_flow > 0 and _trend > 0) or (_flow < 0 and _trend < 0)
    bool momDivAgree = (_mom > 0 and _div > 0) or (_mom < 0 and _div < 0)
    bool structVolAgree = (_structure > 0 and _vol > 0) or (_structure < 0 and _vol < 0)

    // Count agreements
    int agreements = 0
    if flowTrendAgree
        agreements += 1
    if momDivAgree
        agreements += 1
    if structVolAgree
        agreements += 1

    // Additional: Check if all positive or all negative (perfect confluence)
    bool allPositive = _flow > 0 and _mom > 0 and _trend > 0 and _vol > 0 and _structure > 0 and _div > 0
    bool allNegative = _flow < 0 and _mom < 0 and _trend < 0 and _vol < 0 and _structure < 0 and _div < 0

    if allPositive or allNegative
        1.0  // Perfect confluence - all indicators agree
    else
        float(agreements) / 3.0  // Partial confluence

// ===========================================================================
// MAIN HEAT-SCORE CALCULATION
// ===========================================================================
// Returns 0-1 score representing setup quality

calculateHeatScore(float total1, float total2, float total3, float total4, bool includeChart, string setupStatus, float stochRSI, float macdHist, float atrCurrent, float atrAvg, float flow, float mom, float trend, float vol, float structure, float div) =>

    // Calculate individual component scores
    float mtfScore = calculateMTFAlignmentScore(total1, total2, total3, total4, includeChart)
    float signalScore = calculateSignalStrengthScore(total1, total2, total3, total4, includeChart)
    float statusScore = calculateSetupStatusScore(setupStatus)
    float volScore = calculateVolatilityScore(stochRSI, macdHist, atrCurrent, atrAvg)
    float confScore = calculateConfluenceScore(flow, mom, trend, vol, structure, div)

    // Weighted aggregation
    float heatScoreRaw = (mtfScore * WEIGHT_MTF_ALIGNMENT) +
                         (signalScore * WEIGHT_SIGNAL_STRENGTH) +
                         (statusScore * WEIGHT_SETUP_STATUS) +
                         (volScore * WEIGHT_VOLATILITY) +
                         (confScore * WEIGHT_CONFLUENCE)

    // Non-linear stretch: Push values away from 0.5 middle zone
    // pow(x, 1.2) makes middle values less common, extremes more pronounced
    float heatScore = math.pow(heatScoreRaw, 1.2)

    // Ensure 0-1 range
    math.max(0.0, math.min(1.0, heatScore))

// ===========================================================================
// HEAT-SCORE BREAKDOWN (for debugging/display)
// ===========================================================================
// Returns all component scores

getHeatScoreBreakdown(float total1, float total2, float total3, float total4, bool includeChart, string setupStatus, float stochRSI, float macdHist, float atrCurrent, float atrAvg, float flow, float mom, float trend, float vol, float structure, float div) =>

    HeatScoreBreakdown bd = HeatScoreBreakdown.new(na, na, na, na, na, na)
    bd.mtfAlignment := calculateMTFAlignmentScore(total1, total2, total3, total4, includeChart)
    bd.signalStrength := calculateSignalStrengthScore(total1, total2, total3, total4, includeChart)
    bd.setupStatus := calculateSetupStatusScore(setupStatus)
    bd.volatility := calculateVolatilityScore(stochRSI, macdHist, atrCurrent, atrAvg)
    bd.confluence := calculateConfluenceScore(flow, mom, trend, vol, structure, div)
    bd.overall := calculateHeatScore(total1, total2, total3, total4, includeChart, setupStatus, stochRSI, macdHist, atrCurrent, atrAvg, flow, mom, trend, vol, structure, div)
    bd

