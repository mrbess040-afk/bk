// Generate entry signals (two levels: bpc + final)
EntrySignal entryV2 = generateEntries(
    entryDensity,
    marketCtx,
    strengthScore,
    nearSupportForEntry,
    nearResistanceForEntry,
    useBreakoutEntries,
    usePullbackEntries,
    useContinuationEntries,
    allowCounterTrendEntries,
    8,  // lookback for breakout/continuation
    calculateJMA(close, entryJMAFast),
    calculateJMA(close, entryJMASlow),
    strengthThreshold
)

// State machine for entry deduplication
var EntryState entryState = newEntryState()
[entryEvent, newEntryState] = updateEntryStateMachine(
    entryState,
    entryV2.finalLong,
    entryV2.finalShort,
    entryV2.finalLongStrength,
    entryV2.finalShortStrength,
    false, false,
    5,    // entry cooldown
    8,    // warning cooldown (unused)
    0.35  // upgrade delta
)
entryState := newEntryState

// === GENERATE SIGNALS (legacy SignalResult, used by Matrix Table only) ===
TimeframeScores chartTF = mtfScores.chartTF

float signalOptimizedScore = (chartTF.flowScore * 0.40) + (chartTF.momentumScore * 0.40) + (chartTF.trendScore * 0.10) + (chartTF.volatilityScore * 0.05) + (chartTF.structureScore * 0.05)
string chartDirection = signalOptimizedScore > 0 ? "BULLISH" : signalOptimizedScore < 0 ? "BEARISH" : "NEUTRAL"
MultiTimeframeScores chartOnlyScores = MultiTimeframeScores.new(mtfScores.tf1, mtfScores.tf2, mtfScores.tf3, chartTF, signalOptimizedScore, chartDirection, 1, 1)

SignalResult signal = generateSignals(chartOnlyScores, zones, heatBreakdown, mvInterp, exhaust, regime, 0.75, 0.45, true, false, 0.3)

// === SIGNAL QUALITY GATE (ATR + Volume) - Filter Entry V2 finals ===
MarketQuality marketQuality = analyzeMarketQuality(atr, atrSMA, volume, volumeSMA, qualityATRContractThresh, qualityATRExpandThresh, qualityVolLowThresh, qualityVolHighThresh)

// Quality Gate: filter entryV2 finalLong/finalShort
bool qgAllowLong = entryV2.finalLong
bool qgAllowShort = entryV2.finalShort

if useQualityGate
    bool nearSR = zones.nearSupport or zones.nearResistance or zones.atSupport or zones.atResistance

    // Rule 1: Block entries on low volume
    if qualityBlockLowVol and not marketQuality.allowEntries
        qgAllowLong := false
        qgAllowShort := false

    // Rule 2: Block trend signals in range (unless near S/R + mean-rev allowance)
    else if qualityBlockRange and not marketQuality.allowTrendSignals
        if not (qualityAllowMeanReversion and nearSR)
            qgAllowLong := false
            qgAllowShort := false

// Trend filter: regime + JMA50 alignment (suppresses counter-trend entries)
bool trendOkLong  = not useTrendFilter or (regime.isTrending and close > jma50)
bool trendOkShort = not useTrendFilter or (regime.isTrending and close < jma50)

// Heat filter: setup quality gate
bool heatOk = heatBreakdown.overall >= entryHeatMin

// Final strategy signals (used for @strategy-config)
bool finalLong  = qgAllowLong  and entryEvent.emitEntry and entryV2.finalLong  and trendOkLong  and heatOk
bool finalShort = qgAllowShort and entryEvent.emitEntry and entryV2.finalShort and trendOkShort and heatOk

// === EARLY REVERSAL CANDIDATES (informational, pre-entry) ===
bool earlyLongEvidence = (earlyUseDivergence and divZones.nearBullZone) or
     (earlyUseExhaustion and (exhaust.bullWatch or exhaust.bullConfirmed)) or
     (earlyUseExtreme and (rsiOversold or wt1Oversold))
bool earlyShortEvidence = (earlyUseDivergence and divZones.nearBearZone) or
     (earlyUseExhaustion and (exhaust.bearWatch or exhaust.bearConfirmed)) or
     (earlyUseExtreme and (rsiOverbought or wt1Overbought))

bool closeCrossedAboveJma20 = ta.crossover(close, jma20)
bool closeCrossedBelowJma20 = ta.crossunder(close, jma20)
bool earlyLongReaction = not earlyRequirePriceReaction or closeCrossedAboveJma20 or (close > jma20 and close > close[1])
bool earlyShortReaction = not earlyRequirePriceReaction or closeCrossedBelowJma20 or (close < jma20 and close < close[1])
bool earlyLongBiasOk = not regime.isTrending or close < jma50 or regime.isTransitioning
bool earlyShortBiasOk = not regime.isTrending or close > jma50 or regime.isTransitioning

var int lastEarlyLongBar = na
var int lastEarlyShortBar = na
bool earlyLongCooldownOk = na(lastEarlyLongBar) or bar_index - lastEarlyLongBar >= earlyCooldown
bool earlyShortCooldownOk = na(lastEarlyShortBar) or bar_index - lastEarlyShortBar >= earlyCooldown

bool earlyLongCandidate = showEarlyReversal and not finalLong and earlyLongEvidence and earlyLongReaction and earlyLongBiasOk and heatBreakdown.overall >= earlyMinHeat and earlyLongCooldownOk
bool earlyShortCandidate = showEarlyReversal and not finalShort and earlyShortEvidence and earlyShortReaction and earlyShortBiasOk and heatBreakdown.overall >= earlyMinHeat and earlyShortCooldownOk

if earlyLongCandidate
    lastEarlyLongBar := bar_index
if earlyShortCandidate
    lastEarlyShortBar := bar_index

// === RISK MANAGEMENT (ATR-Based SL/TP for Strategy) ===
// Stop Loss
float SL_lvl = finalLong ? close - (atr * atrSLmult) : finalShort ? close + (atr * atrSLmult) : na

// Take Profits (multi-target)
float TP1_lvl = finalLong ? close + (atr * tp1ATRMult) : finalShort ? close - (atr * tp1ATRMult) : na
float TP2_lvl = finalLong ? close + (atr * tp2ATRMult) : finalShort ? close - (atr * tp2ATRMult) : na
float TP3_lvl = finalLong ? close + (atr * tp3ATRMult) : finalShort ? close - (atr * tp3ATRMult) : na

// ============================================================================
// A-SETUP DETECTION (Premium Quality Signals - informational, NOT strategy)
// ============================================================================
// A-Setups are the highest quality signals - clear trend + high heat + momentum
bool isASetupLong = finalLong and heatBreakdown.overall >= 0.65 and strengthScore.longStrength >= 0.70 and regime.isTrending and close > jma50 and jma20 > jma50
bool isASetupShort = finalShort and heatBreakdown.overall >= 0.65 and strengthScore.shortStrength >= 0.70 and regime.isTrending and close < jma50 and jma20 < jma50

float flowScoreChart = mtfScores.chartTF.flowScore
float momScoreChart = mtfScores.chartTF.momentumScore
string regimeLabel = regime.isTrending and flowScoreChart > 0 and momScoreChart > 0 ? "TRENDING UP" : regime.isTrending and flowScoreChart < 0 and momScoreChart < 0 ? "TRENDING DOWN" : regime.isRanging ? "RANGE" : "MIXED"

// ============================================================================
// VISUALIZATION
// ============================================================================

// === MATRIX TABLE ===
if showMatrix
    string matrixStatus = isASetupLong ? "★ A-SETUP LONG" : isASetupShort ? "★ A-SETUP SHORT" : finalLong ? "ENTRY LONG" : finalShort ? "ENTRY SHORT" : setupContext
    drawMatrixTable(mtfScores, signal, heatBreakdown, mvInterp, exhaust, matrixStatus, false, matrixPos)

// === A-SETUP MARKERS (Premium Signals) ===
var array<label> aSetupLabels = array.new<label>()
int MAX_ASETUP_LABELS = 10

if isASetupLong or isASetupShort
    if array.size(aSetupLabels) >= MAX_ASETUP_LABELS
        label oldLabel = array.shift(aSetupLabels)
        label.delete(oldLabel)

    bool isLong = isASetupLong
    float labelY = isLong ? low - (atr * 0.3) : high + (atr * 0.3)
    color aColor = isLong ? color.new(#00E676, 0) : color.new(#FF1744, 0)
    string aTooltip = "A-SETUP " + (isLong ? "LONG" : "SHORT") + "\nHeat: " + str.tostring(heatBreakdown.overall, "#.00") + "\nRegime: " + regimeLabel

    label aLabel = label.new(bar_index, labelY, "★", style=isLong ? label.style_label_up : label.style_label_down, color=aColor, textcolor=color.white, size=size.normal, tooltip=aTooltip)
    array.push(aSetupLabels, aLabel)

// === JMA GRADIENT FILL (Global scope - Pine v6 requirement) ===
p1 = plot(close, display=display.none)
p2 = plot(jma20, display=display.none)
p3 = plot(jma50, display=display.none)
p4 = plot(jma100, display=display.none)
p5 = plot(jma200, display=display.none)
float jmaNeutralBand = atr * jmaNeutralATRBand
color neutralFill1 = color.new(color.gray, 96)
color neutralFill2 = color.new(color.gray, 94)
color neutralFill3 = color.new(color.gray, 93)
color neutralFill4 = color.new(color.gray, 92)
color fillPriceJma20 = math.abs(close - jma20) <= jmaNeutralBand ? neutralFill1 : close > jma20 ? color.new(#00E676, 95) : color.new(#FF1744, 95)
color fillJma20Jma50 = math.abs(jma20 - jma50) <= jmaNeutralBand ? neutralFill2 : jma20 > jma50 ? color.new(#4CAF50, 93) : color.new(#F44336, 93)
color fillJma50Jma100 = math.abs(jma50 - jma100) <= jmaNeutralBand ? neutralFill3 : jma50 > jma100 ? color.new(#81C784, 91) : color.new(#E57373, 91)
color fillJma100Jma200 = math.abs(jma100 - jma200) <= jmaNeutralBand ? neutralFill4 : jma100 > jma200 ? color.new(#A5D6A7, 90) : color.new(#FFCDD2, 90)
fill(p1, p2, color=showJMAGradient ? fillPriceJma20 : na, title="Fill: Price/JMA20")
fill(p2, p3, color=showJMAGradient ? fillJma20Jma50 : na, title="Fill: JMA20/50")
fill(p3, p4, color=showJMAGradient ? fillJma50Jma100 : na, title="Fill: JMA50/100")
fill(p4, p5, color=showJMAGradient ? fillJma100Jma200 : na, title="Fill: JMA100/200")

// === DIAMOND ZONES ===
if showDiamondBoxes
    plotDiamondZones(zones, true)

// === ENTRY ENGINE V2 SIGNAL SHAPES ===
plotshape(earlyLongCandidate, "Early Reversal Long Candidate", shape.triangleup, location.belowbar, color.new(#00BFA5, 20), size=size.tiny, text="ER", textcolor=color.white)
plotshape(earlyShortCandidate, "Early Reversal Short Candidate", shape.triangledown, location.abovebar, color.new(#FF6D00, 20), size=size.tiny, text="ER", textcolor=color.white)
plotshape(finalLong, "Entry Long", shape.triangleup, location.belowbar, color.new(#00E676, 0), size=size.small, text="L", textcolor=color.white)
plotshape(finalShort, "Entry Short", shape.triangledown, location.abovebar, color.new(#FF1744, 0), size=size.small, text="S", textcolor=color.white)

// === CONFIRMED SWING LAYER (visual context only) ===
// Detects price pivots and marks the confirmed extreme. Lags by revPivRight bars.
float revPL = ta.pivotlow(low,  revPivLeft, revPivRight)
float revPH = ta.pivothigh(high, revPivLeft, revPivRight)
bool foundPL = not na(revPL)
bool foundPH = not na(revPH)
HeatScoreBreakdown heatPast = heatBreakdown[revPivRight]
float heatAtPivot = na(heatPast) ? 0.0 : heatPast.overall
// Strict confirmation: pivot must equal the lowest/highest in revStrictWindow bars
bool strictLowOk  = not revStrictMode or low[revPivRight]  <= ta.lowest(low,  revStrictWindow)
bool strictHighOk = not revStrictMode or high[revPivRight] >= ta.highest(high, revStrictWindow)
// Swing magnitude: post-pivot price must have moved minSwingATR×ATR away
float pivLowPrice  = low[revPivRight]
float pivHighPrice = high[revPivRight]
float pivATR       = nz(atr[revPivRight], atr)
float postPivotHigh = ta.highest(high, revPivRight + 1)  // bars [0..revPivRight] inclusive
float postPivotLow  = ta.lowest(low,  revPivRight + 1)
float swingMagLow   = (postPivotHigh - pivLowPrice)  / math.max(pivATR, 0.0001)
float swingMagHigh  = (pivHighPrice - postPivotLow) / math.max(pivATR, 0.0001)
bool swingLowOk  = not revUseSwingFilter or swingMagLow  >= revMinSwingATR
bool swingHighOk = not revUseSwingFilter or swingMagHigh >= revMinSwingATR
bool revLong  = showReversal and foundPL and (not revRequireRegime or heatAtPivot >= revHeatMin) and strictLowOk  and swingLowOk
bool revShort = showReversal and foundPH and (not revRequireRegime or heatAtPivot >= revHeatMin) and strictHighOk and swingHighOk
plotshape(revLong  ? low[revPivRight]  : na, "Confirmed Swing Low",  shape.arrowup,   location.absolute, color.new(#00C853, 0), size=size.small, offset=-revPivRight)
plotshape(revShort ? high[revPivRight] : na, "Confirmed Swing High", shape.arrowdown, location.absolute, color.new(#D50000, 0), size=size.small, offset=-revPivRight)

// === DEBUG: validation dots and log ===
float dbgActualLow  = ta.lowest(low,  dbgLookback)
float dbgActualHigh = ta.highest(high, dbgLookback)
plotshape(dbgShowValidation ? dbgActualLow  : na, "Dbg Lowest",  shape.circle, location.absolute, color.new(#FFD600, 30), size=size.tiny)
plotshape(dbgShowValidation ? dbgActualHigh : na, "Dbg Highest", shape.circle, location.absolute, color.new(#FFD600, 30), size=size.tiny)

if dbgEnabled
    float atrSafe = math.max(atr, 0.0001)
    float majorLow  = ta.lowest(low,  100)
    float majorHigh = ta.highest(high, 100)
    if revLong
        float devLow      = math.abs(dbgActualLow - pivLowPrice) / atrSafe
        float devMajorLow = math.abs(majorLow - pivLowPrice) / atrSafe
        bool isMajor      = devMajorLow < 0.05
        log.info("REV LONG  | pivot=" + str.tostring(pivLowPrice, "#.####") + " | dev(" + str.tostring(dbgLookback) + ")=" + str.tostring(devLow, "#.##") + " | dev_major(100)=" + str.tostring(devMajorLow, "#.##") + " | swing=" + str.tostring(swingMagLow, "#.##") + " ATR | major=" + (isMajor ? "Y" : "N") + " | heat=" + str.tostring(heatAtPivot, "#.##"))
    if revShort
        float devHigh      = math.abs(dbgActualHigh - pivHighPrice) / atrSafe
        float devMajorHigh = math.abs(majorHigh - pivHighPrice) / atrSafe
        bool isMajor       = devMajorHigh < 0.05
        log.info("REV SHORT | pivot=" + str.tostring(pivHighPrice, "#.####") + " | dev(" + str.tostring(dbgLookback) + ")=" + str.tostring(devHigh, "#.##") + " | dev_major(100)=" + str.tostring(devMajorHigh, "#.##") + " | swing=" + str.tostring(swingMagHigh, "#.##") + " ATR | major=" + (isMajor ? "Y" : "N") + " | heat=" + str.tostring(heatAtPivot, "#.##"))
    if finalLong
        float distFromLow = (close - dbgActualLow) / atrSafe
        log.info("ENTRY LONG  | price=" + str.tostring(close, "#.####") + " | dist_from_low(" + str.tostring(dbgLookback) + ")=" + str.tostring(distFromLow, "#.##") + " ATR | heat=" + str.tostring(heatBreakdown.overall, "#.##") + " | strength=" + str.tostring(strengthScore.longStrength, "#.##") + " | regime=" + (regime.isTrending ? "TREND" : "RANGE") + " | trend_ok=" + (trendOkLong ? "Y" : "N"))
    if finalShort
        float distFromHigh = (dbgActualHigh - close) / atrSafe
        log.info("ENTRY SHORT | price=" + str.tostring(close, "#.####") + " | dist_from_high(" + str.tostring(dbgLookback) + ")=" + str.tostring(distFromHigh, "#.##") + " ATR | heat=" + str.tostring(heatBreakdown.overall, "#.##") + " | strength=" + str.tostring(strengthScore.shortStrength, "#.##") + " | regime=" + (regime.isTrending ? "TREND" : "RANGE") + " | trend_ok=" + (trendOkShort ? "Y" : "N"))

// BPC early signals (informational, when no final entry)
bool showBpcLong = entryV2.bpcLong and not entryV2.finalLong
bool showBpcShort = entryV2.bpcShort and not entryV2.finalShort
plotshape(showBpcLong, "BPC Long", shape.circle, location.belowbar, color.new(#4CAF50, 60), size=size.tiny)
plotshape(showBpcShort, "BPC Short", shape.circle, location.abovebar, color.new(#F44336, 60), size=size.tiny)

// === SL / TP LINES (drawn at signal bars) ===
var line slLine = na
var line tp1Line = na
var line tp2Line = na
var line tp3Line = na

if showStopLines and (finalLong or finalShort)
    if not na(slLine)
        line.delete(slLine)
    if not na(tp1Line)
        line.delete(tp1Line)
    if not na(tp2Line)
        line.delete(tp2Line)
    if not na(tp3Line)
        line.delete(tp3Line)

    color slCol = color.new(#FF1744, 30)
    color tpCol = color.new(#00E676, 30)
    slLine := line.new(bar_index, SL_lvl, bar_index + 20, SL_lvl, color=slCol, width=1, style=line.style_dashed)
    tp1Line := line.new(bar_index, TP1_lvl, bar_index + 20, TP1_lvl, color=tpCol, width=1)
    tp2Line := line.new(bar_index, TP2_lvl, bar_index + 20, TP2_lvl, color=tpCol, width=1)
    tp3Line := line.new(bar_index, TP3_lvl, bar_index + 20, TP3_lvl, color=tpCol, width=1)

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(finalLong, title="Entry V2 Long", message="CPM v4: ENTRY LONG signal")
alertcondition(finalShort, title="Entry V2 Short", message="CPM v4: ENTRY SHORT signal")
alertcondition(earlyLongCandidate, title="Early Reversal Long Candidate", message="CPM v4: EARLY REVERSAL LONG candidate (informational)")
alertcondition(earlyShortCandidate, title="Early Reversal Short Candidate", message="CPM v4: EARLY REVERSAL SHORT candidate (informational)")
alertcondition(isASetupLong, title="A-Setup Long", message="CPM v4: A-SETUP LONG (premium)")
alertcondition(isASetupShort, title="A-Setup Short", message="CPM v4: A-SETUP SHORT (premium)")
alertcondition(heatBreakdown.overall >= 0.7, title="High Quality Setup", message="CPM v4: HIGH HEAT SCORE - Quality setup detected")
alertcondition(exhaust.bullConfirmed or exhaust.bearConfirmed, title="Exhaustion Confirmed", message="CPM v4: EXHAUSTION CONFIRMED - Potential reversal")

// ============================================================================
// DEBUG PLOTS (invisible, for alert messages)
// ============================================================================

plot(mtfScores.consensusScore, "Consensus Score", display=display.none)
plot(signal.confidence, "Signal Confidence", display=display.none)
plot(heatBreakdown.overall, "Heat Score", display=display.none)


