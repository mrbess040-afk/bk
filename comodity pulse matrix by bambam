// ==== TYPE DEFINITIONS ====

type ExhaustionResult
    // Individual criteria (true/false)
    bool bullRSI
    bool bullRange
    bool bullVolume
    bool bullWick
    bool bullBody
    bool bearRSI
    bool bearRange
    bool bearVolume
    bool bearWick
    bool bearBody
    // Criteria counts
    int bullCriteriaCount
    int bearCriteriaCount
    // Signals
    bool bullWatch          // 3+ bullish criteria met
    bool bearWatch          // 3+ bearish criteria met
    bool bullConfirmed      // Watch sustained for N bars
    bool bearConfirmed      // Watch sustained for N bars
    // Additional data
    int bullWatchBars      // Consecutive bars in watch state
    int bearWatchBars      // Consecutive bars in watch state

// ===========================================================================
// EXHAUSTION CRITERIA CALCULATION
// ===========================================================================

checkExhaustionCriteria(int rsiLength = 14, int atrLen = 14, int volLength = 20, float atrMultiplier = 1.5, float volMultiplier = 1.3, float wickRatio = 2.0, float wickBodyRatio = 0.5, float bodyMaxPct = 0.3) =>

    // Calculate indicators
    float rsiVal = ta.rsi(close, rsiLength)
    float atrVal = ta.atr(atrLen)
    float atrAvg = ta.sma(atrVal, 20)
    float volAvg = ta.sma(nz(volume), volLength)

    // Calculate candle metrics
    float bodySize = math.abs(close - open)
    float totalRange = high - low
    float upperWick = high - math.max(close, open)
    float lowerWick = math.min(close, open) - low
    float bodyPct = totalRange > 0 ? bodySize / totalRange : 0

    // === BULLISH EXHAUSTION CRITERIA (bottom reversal) ===

    // 1. RSI Extreme (oversold)
    bool bull1_rsi = rsiVal < 20

    // 2. Large Range (ATR expansion - volatility spike)
    bool bull2_range = totalRange > (atrAvg * atrMultiplier)

    // 3. High Volume (panic selling)
    bool bull3_vol = nz(volume) > (volAvg * volMultiplier)

    // 4. Asymmetric Wick (lower wick rejection - buyers stepping in)
    bool bull4_wick = lowerWick > (upperWick * wickRatio) and lowerWick > (bodySize * wickBodyRatio)

    // 5. Small Body (exhaustion - indecision)
    bool bull5_body = bodyPct < bodyMaxPct

    // Count bullish criteria
    int bullCount = 0
    bullCount += bull1_rsi ? 1 : 0
    bullCount += bull2_range ? 1 : 0
    bullCount += bull3_vol ? 1 : 0
    bullCount += bull4_wick ? 1 : 0
    bullCount += bull5_body ? 1 : 0

    // === BEARISH EXHAUSTION CRITERIA (top reversal) ===

    // 1. RSI Extreme (overbought)
    bool bear1_rsi = rsiVal > 80

    // 2. Large Range (ATR expansion - volatility spike)
    bool bear2_range = totalRange > (atrAvg * atrMultiplier)

    // 3. High Volume (panic buying)
    bool bear3_vol = nz(volume) > (volAvg * volMultiplier)

    // 4. Asymmetric Wick (upper wick rejection - sellers stepping in)
    bool bear4_wick = upperWick > (lowerWick * wickRatio) and upperWick > (bodySize * wickBodyRatio)

    // 5. Small Body (exhaustion - indecision)
    bool bear5_body = bodyPct < bodyMaxPct

    // Count bearish criteria
    int bearCount = 0
    bearCount += bear1_rsi ? 1 : 0
    bearCount += bear2_range ? 1 : 0
    bearCount += bear3_vol ? 1 : 0
    bearCount += bear4_wick ? 1 : 0
    bearCount += bear5_body ? 1 : 0

    // Return criteria results
    [bull1_rsi, bull2_range, bull3_vol, bull4_wick, bull5_body, bullCount,
     bear1_rsi, bear2_range, bear3_vol, bear4_wick, bear5_body, bearCount]

// ===========================================================================
// EXHAUSTION SIGNAL WITH CONFIRMATION
// ===========================================================================
// State Machine: Watch (3+ criteria) → Confirmed (sustained for N bars)

detectExhaustion(int confirmBars = 3, int rsiLength = 14, int atrLen = 14, int volLength = 20) =>

    // Check all criteria
    [bull1, bull2, bull3, bull4, bull5, bullCount,
     bear1, bear2, bear3, bear4, bear5, bearCount] = checkExhaustionCriteria(rsiLength, atrLen, volLength)

    // Watch signals (3+ criteria met)
    bool bullWatch = bullCount >= 3
    bool bearWatch = bearCount >= 3

    // Track consecutive watch bars
    var int bullWatchBars = 0
    var int bearWatchBars = 0

    if bullWatch
        bullWatchBars += 1
    else
        bullWatchBars := 0

    if bearWatch
        bearWatchBars += 1
    else
        bearWatchBars := 0

    // Confirmed signals (sustained for N bars)
    bool bullConf = bullWatchBars >= confirmBars
    bool bearConf = bearWatchBars >= confirmBars

    // Return full result
    ExhaustionResult.new(bull1, bull2, bull3, bull4, bull5, bear1, bear2, bear3, bear4, bear5, bullCount, bearCount, bullWatch, bearWatch, bullConf, bearConf, bullWatchBars, bearWatchBars)

// ===========================================================================
// STRICT 5-CRITERIA EXHAUSTION (ALL CRITERIA REQUIRED)
// ===========================================================================
// More rigorous detection - only signals when ALL 5 criteria are met

detectStrictExhaustion(int confirmBars = 3, int rsiLength = 14, int atrLen = 14, int volLength = 20, float rsiOversold = 30, float rsiOverbought = 70, float wickMinPct = 0.3, float bodyMaxPct = 0.25) =>

    // Calculate indicators
    float rsiVal = ta.rsi(close, rsiLength)
    float rng = high - low
    float body = math.abs(close - open)
    float topWick = high - math.max(open, close)
    float botWick = math.min(open, close) - low

    // Ratios
    float wickUpRatio = rng > 0 ? topWick / rng : 0.0
    float wickDnRatio = rng > 0 ? botWick / rng : 0.0
    float bodyRatio = rng > 0 ? body / rng : 1.0

    // Volume comparison
    float volMA = ta.sma(nz(volume), volLength)
    bool bigVol = nz(volume) > volMA

    // Range comparison
    float rngMA = ta.sma(rng, atrLen)
    bool wideRange = rng > rngMA

    // === BEARISH EXHAUSTION (top) ===
    // All 5 criteria must be met
    bool bear1_rsi = rsiVal > rsiOverbought
    bool bear2_range = wideRange
    bool bear3_vol = bigVol
    bool bear4_wick = wickUpRatio >= wickMinPct
    bool bear5_body = bodyRatio <= bodyMaxPct

    bool bearWatch = bear1_rsi and bear2_range and bear3_vol and bear4_wick and bear5_body

    // Confirmation: price must close lower after N bars
    bool bearConf = bearWatch and (confirmBars > 0 ? close[confirmBars] < close : true)

    // === BULLISH EXHAUSTION (bottom) ===
    // All 5 criteria must be met
    bool bull1_rsi = rsiVal < rsiOversold
    bool bull2_range = wideRange
    bool bull3_vol = bigVol
    bool bull4_wick = wickDnRatio >= wickMinPct
    bool bull5_body = bodyRatio <= bodyMaxPct

    bool bullWatch = bull1_rsi and bull2_range and bull3_vol and bull4_wick and bull5_body

    // Confirmation: price must close higher after N bars
    bool bullConf = bullWatch and (confirmBars > 0 ? close[confirmBars] > close : true)

    // Count criteria for output
    int bullCount = (bull1_rsi ? 1 : 0) + (bull2_range ? 1 : 0) + (bull3_vol ? 1 : 0) + (bull4_wick ? 1 : 0) + (bull5_body ? 1 : 0)
    int bearCount = (bear1_rsi ? 1 : 0) + (bear2_range ? 1 : 0) + (bear3_vol ? 1 : 0) + (bear4_wick ? 1 : 0) + (bear5_body ? 1 : 0)

    // Return result
    ExhaustionResult.new(bull1_rsi, bull2_range, bull3_vol, bull4_wick, bull5_body, bear1_rsi, bear2_range, bear3_vol, bear4_wick, bear5_body, bullCount, bearCount, bullWatch, bearWatch, bullConf, bearConf, na, na)

