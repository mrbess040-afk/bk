// CPM v4 - Signal Quality Gate
// ============================================================================

// Analyze market quality using ATR/Volume ratios
// @param atr Current ATR
// @param atrSMA ATR moving average
// @param volume Current volume
// @param volumeSMA Volume moving average
// @param atrContractThresh ATR contraction threshold (e.g., 0.8)
// @param atrExpandThresh ATR expansion threshold (e.g., 1.2)
// @param volLowThresh Volume low threshold (e.g., 0.7)
// @param volHighThresh Volume high threshold (e.g., 1.2)
// @returns MarketQuality object
analyzeMarketQuality( float atr, float atrSMA, float volume, float volumeSMA, float atrContractThresh, float atrExpandThresh, float volLowThresh, float volHighThresh ) =>
    float atrRatio = atrSMA > 0 ? atr / atrSMA : 0.0
    float volRatio = volumeSMA > 0 ? volume / volumeSMA : 0.0

    bool atrContracting = atrRatio > 0 and atrRatio < atrContractThresh
    bool atrExpanding = atrRatio >= atrExpandThresh
    bool volLow = volRatio > 0 and volRatio < volLowThresh
    bool volHigh = volRatio >= volHighThresh

    bool allowEntries = not volLow
    bool allowTrendSignals = not atrContracting

    string qualitySeal = (volLow or atrContracting) ? "POOR" : (atrExpanding and volHigh) ? "GOOD" : "FAIR"

    MarketQuality.new(allowEntries, allowTrendSignals, qualitySeal)


// ============================================================================
// CPM v4 - Risk Management
// ============================================================================

// ==== POSITION SIZING ====

// Calculate position size using fixed risk method
// @param accountSize Total account size (e.g., 100000)
// @param riskPercent Risk per trade as % (e.g., 2.0 = 2%)
// @param entryPrice Entry price
// @param stopLoss Stop-loss price
// @returns PositionSizing object
calculatePositionSize( float accountSize, float riskPercent, float entryPrice, float stopLoss ) =>
    // Calculate dollar risk amount
    float riskAmount = accountSize * (riskPercent / 100.0)

    // Calculate stop distance
    float stopDistance = math.abs(entryPrice - stopLoss)

    // Calculate contracts (contracts = risk / stop distance)
    float contracts = stopDistance > 0 ? riskAmount / stopDistance : 0.0

    // Calculate position value
    float sizeValue = contracts * entryPrice

    // Determine size grade
    string grade = riskPercent >= 2.0 ? "FULL" : riskPercent >= 1.0 ? "REDUCED" : "MINIMAL"

    // Return PositionSizing object
    PositionSizing.new(contracts, sizeValue, riskAmount, riskPercent, grade)

// Calculate regime-aware position size
// Adjusts risk based on market regime
// @param regime Market regime
// @param baseRiskPercent Base risk per trade (%)
// @param entryPrice Entry price
// @param stopLoss Stop-loss price
// @param accountSize Account size
// @returns PositionSizing object with regime adjustment
calculateRegimePositionSize( MarketRegime regime, float baseRiskPercent, float entryPrice, float stopLoss, float accountSize ) =>
    // Adjust risk based on regime
    float adjustedRisk = baseRiskPercent

    if regime.isTrending
        // Increase size in trending markets (1.5x)
        adjustedRisk := baseRiskPercent * 1.5
    else if regime.isRanging
        // Reduce size in ranging markets (0.75x)
        adjustedRisk := baseRiskPercent * 0.75
    else if regime.isTransitioning
        // Minimal size during transitions (0.5x)
        adjustedRisk := baseRiskPercent * 0.5

    // Additional adjustment based on trend strength
    if regime.isTrending
        float strengthMultiplier = 1.0 + ((regime.trendStrength - 50.0) / 100.0)
        adjustedRisk := adjustedRisk * strengthMultiplier

    // Cap risk (0.5% to 3.0%)
    adjustedRisk := math.max(0.5, math.min(3.0, adjustedRisk))

    // Calculate position with adjusted risk
    calculatePositionSize(accountSize, adjustedRisk, entryPrice, stopLoss)

// Calculate Kelly Criterion position size
// @param winRate Historical win rate (0-1)
// @param avgWin Average win size
// @param avgLoss Average loss size
// @param accountSize Account size
// @param kellyFraction Kelly fraction (default 0.25 for quarter Kelly)
// @returns Optimal position size as % of account
calculateKellySize( float winRate, float avgWin, float avgLoss, float accountSize, float kellyFraction = 0.25 ) =>
    // Kelly formula: f = (bp - q) / b
    // b = avg win / avg loss (reward/risk ratio)
    // p = win rate
    // q = 1 - p (loss rate)

    float rewardRiskRatio = avgLoss > 0 ? avgWin / avgLoss : 0.0
    float lossRate = 1.0 - winRate

    float kellyPercent = rewardRiskRatio > 0 ? ((rewardRiskRatio * winRate - lossRate) / rewardRiskRatio) * 100.0 : 0.0

    // Apply Kelly fraction (reduce by fraction)
    float fractionalKelly = kellyPercent * kellyFraction

    // Cap between 0.5% and 5%
    math.max(0.5, math.min(5.0, fractionalKelly))

// ==== STOP-LOSS / TAKE-PROFIT ====

// Calculate ATR-based risk levels
// @param entryPrice Entry price
// @param atr Current ATR value
// @param atrMultSL Stop-loss ATR multiplier (default 2.0)
// @param atrMultTP Take-profit ATR multiplier (default 3.0)
// @param direction Trade direction ("LONG" or "SHORT")
// @returns RiskLevels object
calculateRiskLevels( float entryPrice, float atr, float atrMultSL, float atrMultTP, string direction ) =>
    bool isLong = direction == "LONG"

    // Calculate stop-loss levels
    float slBuy = entryPrice - (atr * atrMultSL)
    float slSell = entryPrice + (atr * atrMultSL)

    // Calculate first take-profit (1:1.5 risk/reward)
    float tp1Buy = entryPrice + (atr * atrMultTP)
    float tp1Sell = entryPrice - (atr * atrMultTP)

    // Calculate second take-profit (1:3 risk/reward)
    float tp2Buy = entryPrice + (atr * atrMultTP * 2.0)
    float tp2Sell = entryPrice - (atr * atrMultTP * 2.0)

    // Initialize trailing stop at stop-loss
    float trailing = isLong ? slBuy : slSell

    // Return RiskLevels object
    RiskLevels.new(slBuy, slSell, tp1Buy, tp1Sell, tp2Buy, tp2Sell, trailing)

// Calculate structure-aware stop-loss
// Uses swing points for better placement
// @param entryPrice Entry price
// @param direction Trade direction ("LONG" or "SHORT")
// @param swingHigh Last swing high
// @param swingLow Last swing low
// @param atr Current ATR
// @param buffer Buffer distance (ATR multiplier, default 0.5)
// @returns Stop-loss price
calculateStructureStopLoss( float entryPrice, string direction, float swingHigh, float swingLow, float atr, float buffer = 0.5 ) =>
    bool isLong = direction == "LONG"

    float stopLoss = 0.0

    if isLong
        // Long: place below swing low with buffer
        stopLoss := swingLow - (atr * buffer)
    else
        // Short: place above swing high with buffer
        stopLoss := swingHigh + (atr * buffer)

    stopLoss

// Update trailing stop
// @param currentStop Current trailing stop
// @param currentPrice Current price
// @param direction Trade direction ("LONG" or "SHORT")
// @param atr Current ATR
// @param trailMultiplier Trail distance (ATR multiplier)
// @returns Updated trailing stop
updateTrailingStop( float currentStop, float currentPrice, string direction, float atr, float trailMultiplier ) =>
    bool isLong = direction == "LONG"

    float newStop = currentStop

    if isLong
        // Long: trail up, never down
        float proposedStop = currentPrice - (atr * trailMultiplier)
        newStop := math.max(currentStop, proposedStop)
    else
        // Short: trail down, never up
        float proposedStop = currentPrice + (atr * trailMultiplier)
        newStop := math.min(currentStop, proposedStop)

    newStop

// ==== RISK QUALITY ASSESSMENT ====

// Assess overall risk quality of trade setup
// @param regime Market regime
// @param score CPM score
// @param volatility Volatility (ATR%)
// @param signalStrength Signal strength (0-1)
// @returns RiskQuality object
assessRiskQuality( MarketRegime regime, float score, float volatility, float signalStrength ) =>
    var concerns = array.new<string>()
    array.clear(concerns)

    float qualityScore = 50.0

    // === REGIME QUALITY ===
    if regime.isTrending
        qualityScore += 25.0
    else if regime.isRanging
        qualityScore -= 15.0
        array.push(concerns, "Ranging market")
    else if regime.isTransitioning
        qualityScore -= 20.0
        array.push(concerns, "Market transitioning")

    // === SCORE STRENGTH ===
    if math.abs(score) >= 4.0
        qualityScore += 15.0
    else if math.abs(score) < 2.0
        qualityScore -= 10.0
        array.push(concerns, "Weak CPM score")

    // === SIGNAL STRENGTH ===
    if signalStrength >= 0.7
        qualityScore += 10.0
    else if signalStrength < 0.4
        qualityScore -= 10.0
        array.push(concerns, "Low signal strength")

    // === VOLATILITY ===
    if volatility > 3.0
        qualityScore -= 15.0
        array.push(concerns, "High volatility")
    else if volatility < 0.5
        qualityScore -= 5.0
        array.push(concerns, "Very low volatility")

    // === TREND STRENGTH ===
    if regime.trendStrength >= 75.0
        qualityScore += 10.0
    else if regime.trendStrength < 30.0
        qualityScore -= 10.0
        array.push(concerns, "Weak trend")

    // Clamp score (0-100)
    qualityScore := clamp100(qualityScore)

    // Determine grade
    string grade = qualityScore >= 80 ? "EXCELLENT" : qualityScore >= 65 ? "GOOD" : qualityScore >= 50 ? "FAIR" : "POOR"

    // Return RiskQuality object
    RiskQuality.new(grade, qualityScore, concerns)

// Assess risk/reward ratio quality
// @param entryPrice Entry price
// @param stopLoss Stop-loss price
// @param takeProfit Take-profit price
// @param minRatio Minimum acceptable R:R (default 1.5)
// @returns [ratio, isAcceptable] tuple
assessRiskRewardRatio( float entryPrice, float stopLoss, float takeProfit, float minRatio = 1.5 ) =>
    float risk = math.abs(entryPrice - stopLoss)
    float reward = math.abs(takeProfit - entryPrice)

    float ratio = risk > 0 ? reward / risk : 0.0
    bool isAcceptable = ratio >= minRatio

    [ratio, isAcceptable]

// ==== EXPOSURE MANAGEMENT ====

// Calculate portfolio heat (total risk exposure)
// @param openPositions Number of open positions
// @param riskPerTrade Risk per trade (%)
// @returns Total portfolio heat (%)
calculatePortfolioHeat(int openPositions, float riskPerTrade) =>
    float totalHeat = openPositions * riskPerTrade
    totalHeat

// Check if portfolio heat is acceptable
// @param portfolioHeat Current portfolio heat (%)
// @param maxHeat Maximum acceptable heat (%, default 6.0)
// @returns True if acceptable
isPortfolioHeatAcceptable(float portfolioHeat, float maxHeat = 6.0) =>
    portfolioHeat <= maxHeat

// Calculate maximum allowed positions
// @param riskPerTrade Risk per trade (%)
// @param maxPortfolioHeat Max portfolio heat (%, default 6.0)
// @returns Maximum number of positions
calculateMaxPositions(float riskPerTrade, float maxPortfolioHeat = 6.0) =>
    int maxPositions = riskPerTrade > 0 ? int(maxPortfolioHeat / riskPerTrade) : 0
    maxPositions

