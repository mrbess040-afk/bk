        "EXCELLENT" => "🟢"
        "GOOD" => "🟡"
        "FAIR" => "🟠"
        "POOR" => "🔴"
        => "⚪"

// Get risk quality color
// @param quality RiskQuality object
// @returns Color for visualization
getRiskQualityColor(RiskQuality quality) =>
    switch quality.grade
        "EXCELLENT" => color.new(color.green, 0)
        "GOOD" => color.new(color.yellow, 0)
        "FAIR" => color.new(color.orange, 0)
        "POOR" => color.new(color.red, 0)
