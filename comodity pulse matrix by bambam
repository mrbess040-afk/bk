    else if category == "trend"
        cat1 := mtfScores.tf1.trendScore
        cat2 := mtfScores.tf2.trendScore
        cat3 := mtfScores.tf3.trendScore
        catChart := mtfScores.chartTF.trendScore
    else if category == "volatility"
        cat1 := mtfScores.tf1.volatilityScore
        cat2 := mtfScores.tf2.volatilityScore
        cat3 := mtfScores.tf3.volatilityScore
