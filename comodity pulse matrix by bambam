// ==== MOMENTUM INDICATORS ====

// Calculate RSI (Relative Strength Index)
// @param length RSI period (default 14)
// @returns RSI value (0-100)
calculateRSI(int length = 14) =>
    ta.rsi(close, length)

// Calculate MACD (Moving Average Convergence Divergence)
// @param fastLen Fast EMA length (default 12)
// @param slowLen Slow EMA length (default 26)
// @param signalLen Signal line length (default 9)
// @returns [macd, signal, histogram] tuple
calculateMACD(int fastLen = 12, int slowLen = 26, int signalLen = 9) =>
    [macdLine, signalLine, histogram] = ta.macd(close, fastLen, slowLen, signalLen)
    [macdLine, signalLine, histogram]

// Calculate CCI (Commodity Channel Index)
// @param length CCI period (default 20)
// @returns CCI value
calculateCCI(int length = 20) =>
    ta.cci(close, length)

// Calculate Stochastic RSI
// @param rsiLen RSI length (default 14)
// @param stochLen Stochastic length (default 14)
// @param kLen K smoothing (default 3)
// @param dLen D smoothing (default 3)
// @returns [K, D] tuple
calculateStochRSI(int rsiLen = 14, int stochLen = 14, int kLen = 3, int dLen = 3) =>
    // Calculate RSI first
    rsiValue = ta.rsi(close, rsiLen)

    // Apply stochastic calculation to RSI
    stochRSI = ta.stoch(rsiValue, rsiValue, rsiValue, stochLen)

    // Smooth with K and D
    k = ta.sma(stochRSI, kLen)
    d = ta.sma(k, dLen)

    [k, d]

// Calculate ROC (Rate of Change)
// @param length ROC period (default 9)
// @returns ROC percentage
calculateROC(int length = 9) =>
    rocPercent(close, length)

// ==== TREND INDICATORS ====

// Calculate ADX (Average Directional Index)
// @param length ADX period (default 14)
// @returns [adx, diPlus, diMinus] tuple
calculateADX(int length = 14) =>
    [diPlus, diMinus, adx] = ta.dmi(length, length)
    [adx, diPlus, diMinus]

// Calculate EMA Stack (20, 50, 200)
// @param len20 EMA 20 length (default 20)
// @param len50 EMA 50 length (default 50)
// @param len200 EMA 200 length (default 200)
// @returns EMAStack type with alignment flags
calculateEMAStack(int len20 = 20, int len50 = 50, int len200 = 200) =>
    ema20 = ta.ema(close, len20)
    ema50 = ta.ema(close, len50)
    ema200 = ta.ema(close, len200)

    // Check alignment
    bullishAlign = ema20 > ema50 and ema50 > ema200
    bearishAlign = ema20 < ema50 and ema50 < ema200

    EMAStack.new(ema20, ema50, ema200, bullishAlign, bearishAlign)

// Calculate single EMA
// @param length EMA length
// @returns EMA value
calculateEMA(int length) =>
    ta.ema(close, length)

// Calculate SMA
// @param length SMA length
// @returns SMA value
calculateSMA(int length) =>
    ta.sma(close, length)

// ==== VOLUME INDICATORS ====

// Calculate MFI (Money Flow Index)
// @param length MFI period (default 14)
// @returns MFI value (0-100)
calculateMFI(int length = 14) =>
    ta.mfi(close, length)

// Calculate OBV (On Balance Volume)
// @returns Current OBV value
calculateOBV() =>
    ta.obv

// Calculate OBV Slope
// @param obvLen OBV smoothing length (default 20)
// @param slopeLen Slope lookback length (default 10)
// @returns OBV slope
calculateOBVSlope(int obvLen = 20, int slopeLen = 10) =>
    obvSmooth = ta.ema(ta.obv, obvLen)
    ta.change(obvSmooth, slopeLen)

// Calculate Volume Ratio (current vs average)
// @param length Average volume period (default 20)
// @returns Volume ratio
calculateVolumeRatio(int length = 20) =>
    float volNz = nz(volume)
    avgVol = ta.sma(volNz, length)
    avgVol > 0 ? volNz / avgVol : 1.0

// Calculate VFI (Volume Flow Indicator)
// @param length VFI period (default 130)
// @param coef Coefficient (default 0.2)
// @param vCoef Volume coefficient (default 2.5)
// @returns VFI value
calculateVFI(int length = 130, float coef = 0.2, float vCoef = 2.5) =>
    // Typical price
    typical = hlc3

    // Volume (nz-guarded for feeds without volume data)
    float vol = nz(volume)

    // Inter calculation
    inter = math.log(typical) - math.log(typical[1])

    // Vinter
    vinter = ta.stdev(inter, 30)

    // Cutoff
    cutoff = coef * vinter * close

    // Vave
    vave = ta.sma(vol, length)[1]

    // Vc calculation
    vc = switch
        vol < vave => vol
        => vave + (vol - vave) * vCoef

    // MF calculation
    mf = typical - typical[1]

    // VCP
    vcp = switch
        mf > cutoff => vc
        mf < -cutoff => -vc
        => 0

    // VFI — guard against vave = 0/na (e.g. early bars or no-volume feeds)
    vfi = vave != 0 and not na(vave) ? ta.sma(vcp, length) / vave : 0.0
    vfi

// ==== VOLATILITY INDICATORS ====

// Calculate ATR (Average True Range)
// @param length ATR period (default 14)
// @returns ATR value
calculateATR(int length = 14) =>
    ta.atr(length)

// Calculate ATR Percentage
// @param length ATR period (default 14)
// @returns ATR as % of price
calculateATRPercent(int length = 14) =>
    atr = ta.atr(length)
    atrPercent(atr, close)

// Calculate Bollinger Bands
// @param length BB period (default 20)
// @param mult Standard deviation multiplier (default 2.0)
// @returns [upper, middle, lower] tuple
calculateBollingerBands(int length = 20, float mult = 2.0) =>
    [upper, middle, lower] = ta.bb(close, length, mult)
    [upper, middle, lower]

// Calculate Bollinger %B
// @param length BB period (default 20)
// @param mult Standard deviation multiplier (default 2.0)
// @returns %B value (0-1, can exceed)
calculateBollingerPercentB(int length = 20, float mult = 2.0) =>
    [upper, middle, lower] = ta.bb(close, length, mult)
    span = upper - lower
    span > 0 ? (close - lower) / span : 0.5

// Calculate Keltner Channels
// @param length Period (default 20)
// @param mult ATR multiplier (default 2.0)
// @returns [upper, middle, lower] tuple
calculateKeltnerChannels(int length = 20, float mult = 2.0) =>
    middle = ta.ema(close, length)
    atr = ta.atr(length)
    upper = middle + (atr * mult)
    lower = middle - (atr * mult)
    [upper, middle, lower]

// ==== OSCILLATOR INDICATORS ====

// Calculate Williams %R
// @param length Period (default 14)
// @returns Williams %R (-100 to 0)
calculateWilliamsR(int length = 14) =>
    highestHigh = ta.highest(high, length)
    lowestLow = ta.lowest(low, length)
    span = highestHigh - lowestLow
    span > 0 ? ((highestHigh - close) / span) * -100 : -50.0

// Calculate Stochastic
// @param length Period (default 14)
// @param kSmooth K smoothing (default 3)
// @param dSmooth D smoothing (default 3)
// @returns [K, D] tuple
calculateStochastic(int length = 14, int kSmooth = 3, int dSmooth = 3) =>
    stoch = ta.stoch(close, high, low, length)
    k = ta.sma(stoch, kSmooth)
    d = ta.sma(k, dSmooth)
    [k, d]

// ==== WAVECYCLE MOMENTUM (CPM PROPRIETARY) ====

// Calculate WaveCycle Momentum oscillator
// @param length WCM period (default 20)
// @param smooth Smoothing period (default 5)
// @returns WCM value (-1 to +1 normalized)
calculateWaveCycleMomentum(int length = 20, int smooth = 5) =>
    // Price momentum
    priceMom = rocPercent(close, length)

    // Volume-weighted momentum
    volWeight = calculateVolumeRatio(length)
    weightedMom = priceMom * volWeight

    // Smooth
    smoothed = ta.ema(weightedMom, smooth)

    // Normalize to -1 to +1
    normalizeOscillator(smoothed, 10.0, -10.0)

// ==== CONSOLIDATED CALCULATION (PERFORMANCE OPTIMIZATION) ====

// Calculate all indicators at once (single pass)
// @param rsiLen RSI length (default 14)
// @param macdFast MACD fast (default 12)
// @param macdSlow MACD slow (default 26)
// @param macdSignal MACD signal (default 9)
// @param cciLen CCI length (default 20)
// @param mfiLen MFI length (default 14)
// @param adxLen ADX length (default 14)
// @param atrLen ATR length (default 14)
// @returns CPMIndicators type with all values
calculateAllIndicators( int rsiLen = 14, int macdFast = 12, int macdSlow = 26, int macdSignal = 9, int cciLen = 20, int mfiLen = 14, int adxLen = 14, int atrLen = 14 ) =>
    // Momentum indicators
    rsi = calculateRSI(rsiLen)
    [macd, macdSig, macdHist] = calculateMACD(macdFast, macdSlow, macdSignal)
    cci = calculateCCI(cciLen)
    [stochK, stochD] = calculateStochRSI()

    // Volume indicators
    mfi = calculateMFI(mfiLen)
    obvSlope = calculateOBVSlope()
    volumeRatio = calculateVolumeRatio()

    // Trend indicators
    [adx, diPlus, diMinus] = calculateADX(adxLen)

    // Volatility indicators
    atr = calculateATR(atrLen)

    // Return consolidated type
