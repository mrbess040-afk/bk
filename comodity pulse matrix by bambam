// Format risk concerns for display
// @param quality RiskQuality object
// @returns Formatted concerns string
formatRiskConcerns(RiskQuality quality) =>
    string output = ""
    int size = array.size(quality.concerns)

    if size == 0
        output := "No concerns"
    else
        for i = 0 to size - 1
            concern = array.get(quality.concerns, i)
            output := output + (i > 0 ? ", " : "") + concern

    output

// Calculate risk amount from position size
// @param contracts Number of contracts
// @param entryPrice Entry price
// @param stopLoss Stop-loss price
// @returns Risk amount in currency
calculateRiskAmount(float contracts, float entryPrice, float stopLoss) =>
    float stopDistance = math.abs(entryPrice - stopLoss)
    float riskAmount = contracts * stopDistance
    riskAmount

// Calculate position value
// @param contracts Number of contracts
// @param price Current price
// @returns Position value
calculatePositionValue(float contracts, float price) =>
    contracts * price

// Calculate profit/loss
// @param contracts Number of contracts
// @param entryPrice Entry price
// @param exitPrice Exit price
// @param direction Trade direction ("LONG" or "SHORT")
// @returns P/L amount
calculateProfitLoss( float contracts, float entryPrice, float exitPrice, string direction ) =>
    bool isLong = direction == "LONG"

    float pl = 0.0

    if isLong
        pl := contracts * (exitPrice - entryPrice)
    else
        pl := contracts * (entryPrice - exitPrice)

    pl

// Calculate profit/loss percentage
// @param entryPrice Entry price
// @param exitPrice Exit price
// @param direction Trade direction
// @returns P/L percentage
calculateProfitLossPercent( float entryPrice, float exitPrice, string direction ) =>
    bool isLong = direction == "LONG"

    float plPercent = 0.0

    if isLong
        plPercent := ((exitPrice - entryPrice) / entryPrice) * 100.0
    else
        plPercent := ((entryPrice - exitPrice) / entryPrice) * 100.0

    plPercent

// Check if stop-loss is hit
// @param currentPrice Current price
// @param stopLoss Stop-loss price
// @param direction Trade direction
// @returns True if stopped out
isStoppedOut(float currentPrice, float stopLoss, string direction) =>
    bool isLong = direction == "LONG"

    bool stoppedOut = false

    if isLong
        stoppedOut := currentPrice <= stopLoss
    else
        stoppedOut := currentPrice >= stopLoss

    stoppedOut

// Check if take-profit is hit
// @param currentPrice Current price
// @param takeProfit Take-profit price
// @param direction Trade direction
// @returns True if TP hit
isTakeProfitHit(float currentPrice, float takeProfit, string direction) =>
    bool isLong = direction == "LONG"

    bool tpHit = false

    if isLong
        tpHit := currentPrice >= takeProfit
    else
        tpHit := currentPrice <= takeProfit

    tpHit


