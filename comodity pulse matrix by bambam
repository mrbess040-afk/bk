// ==== JURIK MOVING AVERAGE (JMA) ====

calculateJMA(float src, int length, float phase = 0.0, float power = 2.0) =>
    float phaseRatio = phase < -100 ? 0.5 : phase > 100 ? 2.5 : phase / 100 + 1.5
    float beta = 0.45 * (length - 1) / (0.45 * (length - 1) + 2)
    float alpha = math.pow(beta, power)

    var float e0 = na
    var float e1 = na
    var float e2 = na
    var float jma = na

    e0 := (1 - alpha) * src + alpha * nz(e0[1], src)
    e1 := (src - e0) * (1 - beta) + beta * nz(e1[1], 0)
    e2 := (e0 + phaseRatio * e1 - nz(jma[1], src)) * math.pow(1 - alpha, 2) + math.pow(alpha, 2) * nz(e2[1], 0)
    jma := e2 + nz(jma[1], src)
    jma

// ===========================================================================
// Z-SCORE NORMALIZATION HELPER
// ===========================================================================

// Standardized Z-Score normalization for robust cross-asset comparison
// Returns value normalized to [-1, 1] range after Z-Score calculation
zLocal(float x, int len) =>
    float m = ta.sma(x, len)
    float s = ta.stdev(x, len)
    s == 0.0 ? 0.0 : (x - m) / s

// ===========================================================================
// NORMALIZATION UTILITIES
// ===========================================================================

// Linear normalization: map value from [inMin, inMax] to [outMin, outMax]
normalize(float val, float inMin, float inMax, float outMin = 0.0, float outMax = 1.0) =>
    float rangeVal = inMax - inMin
    rangeVal == 0.0 ? outMin : outMin + ((val - inMin) / rangeVal) * (outMax - outMin)

// Non-zero map: map value from [low, high] to [0, 1], handle zero
nzmap(float val, float low, float high) =>
    float mapped = (val - low) / math.max(0.001, high - low)
    math.max(0.0, math.min(1.0, mapped))

// ===========================================================================
// 1. FLOW SCORE CALCULATION
// ===========================================================================
// Combines Money Flow Index (MFI), On-Balance Volume (OBV), and Volume Flow Indicator (VFI)
// Weight Distribution: MFI 50%, VFI 30%, OBV 20%

calculateFlowScore(float mfi, float closePrice, float volume, float obvSlope, int zLen = 50) =>
    // MFI Component (0-100 oscillator)
    float mfiZ = zLocal(mfi, zLen)

    // Volume Flow Indicator (VFI) - Price-weighted volume momentum
    float typical = (high + low + close) / 3.0
    float inter = math.log(typical) - math.log(typical[1])
    float vinter = ta.stdev(inter, 30)
    float cutoff = 0.2 * vinter * close
    float volNz = nz(volume)
    float volumeSma = ta.sma(volNz, 30)  // Extract ta.sma for consistency
    float vcp = math.abs(close - close[1]) > cutoff and volumeSma * cutoff != 0 ? volNz * (close - close[1]) / (volumeSma * cutoff) : 0.0
    float vfi = calculateJMA(vcp, 30)  // JMA instead of EMA
    float vfiZ = zLocal(vfi, zLen)

    // OBV Slope Component (may be na in MTF mode) - Extract z() for consistency
    float obvZ_raw = zLocal(obvSlope, zLen)
    float obvZ = na(obvSlope) ? 0.0 : obvZ_raw

    // Weighted combination (adjust weights if OBV is disabled)
    float flowScore = na(obvSlope) ? (mfiZ * 0.625) + (vfiZ * 0.375) : (mfiZ * 0.5) + (vfiZ * 0.3) + (obvZ * 0.2)

    // Clamp to ±3 sigma and normalize to [-1, 1]
    math.max(-3.0, math.min(3.0, flowScore)) / 3.0

// ===========================================================================
// 2. MOMENTUM SCORE CALCULATION
// ===========================================================================
// Combines RSI, Rate of Change (ROC), Stochastic RSI, and Commodity Channel Index (CCI)
// Note: WaveCycle Momentum (WCM) is calculated in separate wcm_oscillator.pine module

calculateMomentumScore(float rsi, float cci, float roc, float src, int zLen = 50, bool useWCM = false) =>
    // RSI Component (0-100 oscillator)
    float rsiZ = zLocal(rsi, zLen)

    // Rate of Change Component
    float rocZ = zLocal(roc, zLen)

    // Stochastic RSI Component
    float rsiStoch = ta.stoch(rsi, rsi, rsi, 14)
    float stochNorm = (rsiStoch - 50.0) / 50.0  // Convert to [-1, 1]

    // CCI Component (Commodity Channel Index)
    float cciNorm = math.max(-3.0, math.min(3.0, cci / 100.0)) / 3.0  // Normalize from typical ±300 range

    // WCM REMOVED: Memory optimization for 2H+ timeframes
    // Rebalanced weights WITHOUT WCM (10% redistributed):
    // RSI 27.5% (+2.5%), ROC 22.5% (+2.5%), StochRSI 37.5% (+2.5%), CCI 12.5% (+2.5%)
    // Rebalanced weights (RSI 27.5%, ROC 22.5%, StochRSI 37.5%, CCI 12.5%)
    float momScore = (rsiZ * 0.275) + (rocZ * 0.225) + (stochNorm * 0.375) + (cciNorm * 0.125)
    // Clamp to ±3 sigma and normalize
    math.max(-3.0, math.min(3.0, momScore)) / 3.0

// ===========================================================================
// 3. TREND SCORE CALCULATION
// ===========================================================================
// Combines ADX strength, DMI directional indicators, EMA stack alignment, and VWAP position

calculateTrendScore(float adx, int emaStackDir, float diPlus, float diMinus, float closePrice, float vwap, int zLen = 50) =>
    // ADX Strength Component (0-100, threshold 25 for trending)
    float adxNorm = nzmap(adx, 15, 35)  // Map 15-35 to 0-1

    // DMI Directional Component
    float adxDir = adx > 25 ? (diPlus > diMinus ? 1.0 : -1.0) : 0.0

    // EMA Stack Component (-1 = bearish, 0 = mixed, +1 = bullish)
    float emaContrib = emaStackDir  // Already normalized to [-1, 1]

    // VWAP Position Component (may be na in MTF mode)
    float vwapNorm = 0.0
    if not na(vwap)
        float vwapDist = (closePrice - vwap) / vwap
        vwapNorm := math.max(-0.05, math.min(0.05, vwapDist)) / 0.05  // ±5% range

    // Weighted combination (adjust if VWAP is disabled)
    // ADX+DMI 50%, EMA Stack 35%, VWAP 15%
    float trendScore = na(vwap) ? (adxNorm * adxDir * 0.59) + (emaContrib * 0.41) : (adxNorm * adxDir * 0.50) + (emaContrib * 0.35) + (vwapNorm * 0.15)

    // Already in [-1, 1] range
    math.max(-1.0, math.min(1.0, trendScore))

// ===========================================================================
// 4. VOLATILITY SCORE CALCULATION
// ===========================================================================
// Combines ATR%, Bollinger Band Squeeze, and Williams VIX Fix (WVF)
// Lower volatility = positive score, higher volatility = negative score

calculateVolatilityScore(float atr, float closePrice, float src, bool useSqueeze = true, int zLen = 50) =>
    // ATR% Component (volatility as % of price)
    float atrPct = (atr / closePrice) * 100.0
    float atrNorm = nzmap(atrPct, 0.5, 3.0)  // Map 0.5-3% to 0-1
    float atrScore = 1.0 - atrNorm  // Invert: low volatility = positive

    // Bollinger Band Squeeze Component - Extract ta.* calls for consistency
    float basis = ta.sma(src, 20)
    float dev = ta.stdev(src, 20)
    float keltnerBasis = calculateJMA(src, 20)
    float keltnerRange = calculateJMA(ta.tr, 20)

    float sqzContrib = 0.0
    if useSqueeze
        float upperBB = basis + (2.0 * dev)
        float lowerBB = basis - (2.0 * dev)
        float upperKC = keltnerBasis + (1.5 * keltnerRange)
        float lowerKC = keltnerBasis - (1.5 * keltnerRange)
        bool squeeze = (lowerBB > lowerKC) and (upperBB < upperKC)
        sqzContrib := squeeze ? 0.3 : 0.0  // Squeeze = potential breakout = positive

    // Williams VIX Fix (WVF) - Market bottom indicator
    float highest_close = ta.highest(close, 22)
    float wvf = ((highest_close - low) / highest_close) * 100.0
    float wvfMA = ta.sma(wvf, 22)
    float wvfBoost = wvf > wvfMA ? 0.2 : 0.0  // High WVF = potential reversal = positive

    // Weighted combination
    // ATR 50%, Squeeze 30%, WVF 20%
    float volScore = (atrScore * 0.50) + (sqzContrib * 0.30) + (wvfBoost * 0.20)

    // Convert to [-1, 1] range (currently [0, 1])
    (volScore * 2.0) - 1.0

// ===========================================================================
// 5. STRUCTURE SCORE CALCULATION
// ===========================================================================
// Combines price position relative to EMAs and Donchian Channel breakouts

calculateStructureScore(float closePrice, float ema20, float ema50, float ema200, float highVal, float lowVal, int donchianLen = 20) =>
    // EMA Position Components
    float above20 = closePrice > ema20 ? 1.0 : -1.0
    float above50 = closePrice > ema50 ? 1.0 : -1.0
    float above200 = na(ema200) ? 0.0 : closePrice > ema200 ? 1.0 : -1.0  // Handle na in MTF

    // EMA distance (normalized)
    float dist20 = (closePrice - ema20) / ema20
    float dist50 = (closePrice - ema50) / ema50
    float dist200 = na(ema200) ? 0.0 : (closePrice - ema200) / ema200

    // Adjust distance calculation if ema200 is disabled
    float distScore = na(ema200) ? (dist20 * 0.625) + (dist50 * 0.375) : (dist20 * 0.5) + (dist50 * 0.3) + (dist200 * 0.2)
    float distNorm = math.max(-0.10, math.min(0.10, distScore)) / 0.10  // ±10% range

    // Donchian Channel Breakout (20-period high/low)
    float donchHigh = ta.highest(highVal, donchianLen)
    float donchLow = ta.lowest(lowVal, donchianLen)
    float donchBreakout = closePrice >= donchHigh ? 1.0 : closePrice <= donchLow ? -1.0 : 0.0

    // Weighted combination (adjust if ema200 is disabled)
    // Position above EMAs 40%, Distance from EMAs 40%, Donchian Breakout 20%
    float emaPositionScore = na(ema200) ? (above20 * 0.571) + (above50 * 0.429) : (above20 * 0.4) + (above50 * 0.3) + (above200 * 0.3)
    float structScore = (emaPositionScore * 0.40) + (distNorm * 0.40) + (donchBreakout * 0.20)

    // Already in [-1, 1] range
    math.max(-1.0, math.min(1.0, structScore))

// ===========================================================================
// 6. DIVERGENCE SCORE CALCULATION
// ===========================================================================
// Simple divergence detection using pivot points
// Combines regular and hidden divergences with strength scoring

calculateDivergenceScore(float oscillator, int leftBars = 5, int rightBars = 5) =>
    // Detect pivot highs/lows in price and oscillator (returns float or na)
    float pricePivotHigh = ta.pivothigh(high, leftBars, rightBars)
    float pricePivotLow = ta.pivotlow(low, leftBars, rightBars)
    float oscPivotHigh = ta.pivothigh(oscillator, leftBars, rightBars)
    float oscPivotLow = ta.pivotlow(oscillator, leftBars, rightBars)

    // Extract ta.valuewhen calls for consistency
    float prevPriceLow = ta.valuewhen(not na(pricePivotLow), low, 1)
    float prevOscLow = ta.valuewhen(not na(oscPivotLow), oscillator, 1)
    float prevPriceHigh = ta.valuewhen(not na(pricePivotHigh), high, 1)
    float prevOscHigh = ta.valuewhen(not na(oscPivotHigh), oscillator, 1)

    float divScore = 0.0

    // Bullish Regular Divergence: Price makes lower low, oscillator makes higher low
    if not na(pricePivotLow) and not na(oscPivotLow)
        if not na(prevPriceLow) and not na(prevOscLow)
            if low < prevPriceLow and oscillator > prevOscLow
                divScore += 0.5

    // Bearish Regular Divergence: Price makes higher high, oscillator makes lower high
    if not na(pricePivotHigh) and not na(oscPivotHigh)
        if not na(prevPriceHigh) and not na(prevOscHigh)
            if high > prevPriceHigh and oscillator < prevOscHigh
                divScore -= 0.5

    // Clamp to [-1, 1] range
    math.max(-1.0, math.min(1.0, divScore))

// ===========================================================================
// AGGREGATE SCORE CALCULATION
// ===========================================================================
// Combines all 6 category scores with configurable weights

calculateAggregateScore(float flowScore, float momScore, float trendScore, float volScore, float structScore, float divScore, float flowWeight, float momWeight, float trendWeight, float volWeight, float structWeight, float divWeight) =>
    // Weighted sum
    float totalScore = (flowScore * flowWeight) +
                       (momScore * momWeight) +
                       (trendScore * trendWeight) +
                       (volScore * volWeight) +
                       (structScore * structWeight) +
                       (divScore * divWeight)

    // Normalize by total weight
    float totalWeight = flowWeight + momWeight + trendWeight + volWeight + structWeight + divWeight
    float normalizedScore = totalScore / totalWeight

    // Clamp to [-1, 1] range
    math.max(-1.0, math.min(1.0, normalizedScore))

