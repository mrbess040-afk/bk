// ==== TYPE DEFINITIONS ====

type MVInterpretation
    float score
    string direction
    string quality
    bool volumeConfirmed
    bool volumeWarning
    bool volumeSurge

// ===========================================================================
// VOLUME RELATIVE STRENGTH
// ===========================================================================
// Compares current volume to average (normalized)

calculateVolumeRelative(float volumeVal, float volumeAvg) =>
    if volumeAvg > 0
        volumeVal / volumeAvg
    else
        1.0

// ===========================================================================
// VOLUME QUALITY SCORE (0-1)
// ===========================================================================
// Scores volume based on relative strength and consistency

calculateVolumeQualityScore(float volRelative, float volStdDev, int lookback) =>
    // High relative volume = better (1.5+ = excellent)
    float relativeScore = 0.0
    if volRelative >= 2.0
        relativeScore := 1.0  // Exceptional volume
    else if volRelative >= 1.5
        relativeScore := 0.8  // Very high volume
    else if volRelative >= 1.2
        relativeScore := 0.6  // High volume
    else if volRelative >= 1.0
        relativeScore := 0.4  // Average volume
    else
        relativeScore := 0.2  // Low volume

    // Low std dev = consistent volume = better
    float volAvg = ta.sma(volume, lookback)
    float consistencyScore = volAvg > 0 ? 1.0 - math.min(1.0, volStdDev / volAvg) : 0.5

    // Combine (70% relative strength, 30% consistency)
    (relativeScore * 0.7) + (consistencyScore * 0.3)

// ===========================================================================
// MOMENTUM-VOLUME ALIGNMENT
// ===========================================================================
// Checks if volume confirms momentum direction

checkMVAlignment(float wcmDirection, float volRelative) =>
    // Strong momentum should have high volume
    bool strongMomentum = math.abs(wcmDirection) > 0.5
    bool highVolume = volRelative > 1.2

    // Aligned = strong momentum + high volume (good signal)
    bool aligned = strongMomentum and highVolume

    // Misaligned = strong momentum + low volume (warning!)
    bool misaligned = strongMomentum and volRelative < 0.8

    [aligned, misaligned]

// ===========================================================================
// MV-CONFLUENCE SCORE (Main)
// ===========================================================================
// Formula: Direction × Strength × Volume Quality
// Range: -1 to +1 (negative=bearish, positive=bullish)
// Magnitude indicates quality

calculateMVScore(float rsiValue, float volumeVal, float volumeAvg, float volStdDev, int lookback = 20) =>

    // WCM REMOVED: Use RSI-based momentum instead
    // RSI to direction/strength conversion (simpler than WCM, no 250-bar lookback)
    float direction = (rsiValue - 50.0) / 50.0  // -1 to +1 (normalized RSI)
    float strength = math.abs(direction)         // 0 to 1

    // Calculate volume components
    float volRelative = calculateVolumeRelative(volumeVal, volumeAvg)
    float volQuality = calculateVolumeQualityScore(volRelative, volStdDev, lookback)

    // MV Score = Direction × Strength × Volume Quality
    // This preserves direction while scaling by quality
    float mvScore = direction * strength * volQuality

    mvScore

// ===========================================================================
// VOLUME SURGE DETECTION
// ===========================================================================
// Detects abnormal volume spikes (potential breakout/breakdown)

detectVolumeSurge(float volumeVal, float volumeAvg, float volStdDev) =>
    // Threshold: 2 standard deviations above average
    float threshold = volumeAvg + (2.0 * volStdDev)
    bool surge = volumeVal > threshold
    float intensity = volStdDev > 0 ? (volumeVal - volumeAvg) / volStdDev : 0.0

    [surge, intensity]

// ===========================================================================
// MV-CONFLUENCE WITH SURGE BOOST
// ===========================================================================
// Enhanced MV score that boosts on volume surges

calculateMVScoreWithSurge(float rsiValue, float volumeVal, float volumeAvg, float volStdDev, int lookback = 20) =>

    // Base MV score
    float baseMV = calculateMVScore(rsiValue, volumeVal, volumeAvg, volStdDev, lookback)

    // Volume surge detection
    [surge, intensity] = detectVolumeSurge(volumeVal, volumeAvg, volStdDev)

    float mvScore = baseMV
    if surge
        // Boost score by surge intensity (max 20% boost)
        float boost = math.min(0.2, intensity * 0.05)
        float direction = baseMV > 0 ? 1.0 : -1.0
        mvScore := baseMV + (direction * boost)
        mvScore := math.max(-1.0, math.min(1.0, mvScore))

    [mvScore, surge, intensity]

// ===========================================================================
// MV-SCORE INTERPRETATION
// ===========================================================================
// Converts raw MV score to actionable interpretation

interpretMVScore(float mvScore, float momentumDirection, float volRelative, bool volumeSurge = false, float surgeIntensity = 0.0) =>

    MVInterpretation interp = MVInterpretation.new(mvScore, "", "", false, false, volumeSurge)

    // Direction classification
    if mvScore > 0.3
        interp.direction := "BULLISH"
    else if mvScore < -0.3
        interp.direction := "BEARISH"
    else
        interp.direction := "NEUTRAL"

    // Quality classification (based on absolute score magnitude)
    float absScore = math.abs(mvScore)
    if absScore >= 0.7
        interp.quality := "EXCELLENT"  // High confidence signal
    else if absScore >= 0.5
        interp.quality := "GOOD"       // Good quality signal
    else if absScore >= 0.3
        interp.quality := "MODERATE"   // Acceptable signal
    else
        interp.quality := "WEAK"       // Low confidence signal

    // Volume confirmation check
    [aligned, misaligned] = checkMVAlignment(momentumDirection, volRelative)
    interp.volumeConfirmed := aligned
    interp.volumeWarning := misaligned

    interp

// ===========================================================================
// COMPLETE MV ANALYSIS
// ===========================================================================
// All-in-one function for full MV confluence analysis

analyzeMVConfluence(float rsiValue, float volumeVal, int lookback = 20) =>

    // Calculate volume statistics
    float volumeAvg = ta.sma(volume, lookback)
    float volStdDev = ta.stdev(volume, lookback)
    float volRelative = calculateVolumeRelative(volumeVal, volumeAvg)

    // Calculate MV score with surge detection
    [mvScore, surge, intensity] = calculateMVScoreWithSurge(rsiValue, volumeVal, volumeAvg, volStdDev, lookback)

    // Get momentum direction from RSI
    float momentumDirection = (rsiValue - 50.0) / 50.0  // -1 to +1

    // Interpret results
    MVInterpretation interp = interpretMVScore(mvScore, momentumDirection, volRelative, surge, intensity)

    interp

