// Calculate Prediction and Confirmation Scores from chart timeframe
// Prediction Score: Fast response (Momentum 60% + Flow 40%)
// Confirmation Score: Stable (Momentum 40% + Flow 40% + Trend 20%)
calculateDualScore( TimeframeScores chartTF, float predictionThreshold = 0.02, float confirmationThreshold = 0.05 ) =>

    // Extract category scores
    float momentum = chartTF.momentumScore
    float flow = chartTF.flowScore
    float trend = chartTF.trendScore

    // PREDICTION SCORE: Fast response (no trend, max momentum weight)
    // Goal: Catch setup EARLY (1-3 bars before move)
    float predictionScore = (momentum * 0.60) + (flow * 0.40)

    // CONFIRMATION SCORE: Balanced and stable
    // Goal: Confirm setup is VALID (entry trigger)
    float confirmationScore = (momentum * 0.40) + (flow * 0.40) + (trend * 0.20)

    // Check thresholds
    bool predictionBull = predictionScore > predictionThreshold
    bool predictionBear = predictionScore < -predictionThreshold
    bool confirmationBull = confirmationScore > confirmationThreshold
    bool confirmationBear = confirmationScore < -confirmationThreshold

    // Generate signal strings
    string predictionSignal = predictionBull ? "BUY" : predictionBear ? "SELL" : "NONE"
    string confirmationSignal = confirmationBull ? "BUY" : confirmationBear ? "SELL" : "NONE"

    // Create result
    DualScore result = DualScore.new( predictionScore, confirmationScore, predictionBull, predictionBear, confirmationBull, confirmationBear, predictionSignal, confirmationSignal )

    result

// Get dual-score quality assessment
getDualScoreQuality(DualScore dualScore) =>
    string quality = "INVALID"

    // STRONG: Both prediction AND confirmation agree
    if (dualScore.predictionBull and dualScore.confirmationBull) or
       (dualScore.predictionBear and dualScore.confirmationBear)
        quality := "STRONG"

    // MODERATE: Only confirmation (missed prediction window)
    else if dualScore.confirmationBull or dualScore.confirmationBear
        quality := "MODERATE"

    // EARLY: Only prediction (setup forming, not confirmed yet)
    else if dualScore.predictionBull or dualScore.predictionBear
        quality := "EARLY"

    quality

