    float _ema20 = hasIndicators ? indicators.ema20 : close
    float _ema50 = hasIndicators ? indicators.ema50 : close
    float _ema200 = hasIndicators ? indicators.ema200 : close
    float _volume = hasIndicators ? indicators.volume : volume
    float _obvSlope = hasIndicators ? indicators.obvSlope : 0.0

    // Calculate all scores (always called for consistency)
    float flowScore = calculateFlowScore(_mfi, close, _volume, _obvSlope)
    float momentumScore = calculateMomentumScore(_rsi, _cci, _roc, close, 50, false)
    float trendScore = calculateTrendScore(_adx, _emaStackDir, _diPlus, _diMinus, close, _vwap)
    float volatilityScore = calculateVolatilityScore(_atr, close, close, false)
    float structureScore = calculateStructureScore(close, _ema20, _ema50, _ema200, high, low)
    float divergenceScore = calculateDivergenceScore(_rsi, 5, 5)

    // Calculate weighted total
    float totalScore = calculateAggregateScore( flowScore, momentumScore, trendScore, volatilityScore, structureScore, divergenceScore, flowW, momW, trendW, volW, structW, divW)

    // Return score structure (with validity flag)
    TimeframeScores.new(flowScore, momentumScore, trendScore, volatilityScore, structureScore, divergenceScore, totalScore, flowW, momW, trendW, volW, structW, divW, timeframe, hasIndicators)

