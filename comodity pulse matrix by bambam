// ===========================================================================
// 1. MTF ALIGNMENT SCORE (0-1)
// ===========================================================================
// Measures how many timeframes agree on direction

calculateMTFAlignmentScore(float total1, float total2, float total3, float total4, bool includeChart) =>
    // Guard against na values - treat na as neutral (0)
    float t1 = nz(total1, 0.0)
    float t2 = nz(total2, 0.0)
    float t3 = nz(total3, 0.0)
    float t4 = nz(total4, 0.0)

    // Direction: positive=bullish, negative=bearish, zero=neutral
    int dir1 = t1 > 0 ? 1 : t1 < 0 ? -1 : 0
    int dir2 = t2 > 0 ? 1 : t2 < 0 ? -1 : 0
    int dir3 = t3 > 0 ? 1 : t3 < 0 ? -1 : 0
    int dir4 = t4 > 0 ? 1 : t4 < 0 ? -1 : 0

    // Count TFs in dominant direction
    int tfCount = includeChart ? 4 : 3
    int maxDir = dir1 + dir2 + dir3 + (includeChart ? dir4 : 0)
    int dominantDir = maxDir > 0 ? 1 : maxDir < 0 ? -1 : 0

    int aligned = 0
    if dominantDir != 0
        if dir1 == dominantDir
            aligned += 1
        if dir2 == dominantDir
            aligned += 1
        if dir3 == dominantDir
            aligned += 1
        if includeChart and dir4 == dominantDir
            aligned += 1

    // Return 0-1 score
    float(aligned) / float(tfCount)

// ===========================================================================
// 2. SIGNAL STRENGTH SCORE (0-1)
// ===========================================================================
// Measures magnitude of signals across TFs

calculateSignalStrengthScore(float total1, float total2, float total3, float total4, bool includeChart) =>
    // Guard against na values - treat na as 0
    float t1 = nz(total1, 0.0)
    float t2 = nz(total2, 0.0)
    float t3 = nz(total3, 0.0)
    float t4 = nz(total4, 0.0)

    // Average absolute score (stronger signals = higher)
    float sum = math.abs(t1) + math.abs(t2) + math.abs(t3) + (includeChart ? math.abs(t4) : 0)
    int count = includeChart ? 4 : 3
    float avgMagnitude = sum / float(count)

    // Normalize: 0=weak, 2.5+=strong
    // Score range: 0-1 where 2.5+ magnitude = 1.0
    math.min(1.0, avgMagnitude / 2.5)

