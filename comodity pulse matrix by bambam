// ============================================================================
// TREND & RANGE DETECTION (Chart-TF)
// ============================================================================
// NOTE: calculateJMA() is defined centrally in cpm_calculations.pine

// JMA-based trend detection (replaces EMA for lower lag and fewer whipsaws)
// Fast JMA: responsive to price changes (short length, positive phase)
// Slow JMA: smooth trend line (longer length, neutral phase)
detectTrend(int jmaFastLen, int jmaSlowLen) =>
    // Fast JMA: more responsive (phase=50 for slight overshoot, power=2)
    float jmaFast = calculateJMA(close, jmaFastLen, 50, 2)

    // Slow JMA: smoother trend (phase=0 balanced, power=2)
    float jmaSlow = calculateJMA(close, jmaSlowLen, 0, 2)

    bool up = jmaFast > jmaSlow
    bool down = jmaFast < jmaSlow

    [up, down, jmaFast, jmaSlow]

// ATR-based ranging detection
detectRanging(int atrLen, int atrSmaLen, float compressThresh) =>
    float atr = ta.atr(atrLen)
    float atrSma = ta.sma(atr, atrSmaLen)
    float atrNorm = atr / atrSma

    bool ranging = atrNorm < compressThresh

    [ranging, atr, atrNorm]

// Volatility Stop (ATR-based trend bias)
calculateVolStop(float atr, float mult) =>
    float hl2Avg = (high + low) / 2

    float basicUpperBand = hl2Avg + mult * atr
    float basicLowerBand = hl2Avg - mult * atr

    // Trend-following bands
    var float volStopLong = na
    var float volStopShort = na

    // Long stop (rises, doesn't fall)
    float newLongStop = basicLowerBand
    volStopLong := na(volStopLong[1]) ? newLongStop : close[1] > volStopLong[1] ? math.max(newLongStop, volStopLong[1]) : newLongStop

    // Short stop (falls, doesn't rise)
    float newShortStop = basicUpperBand
    volStopShort := na(volStopShort[1]) ? newShortStop : close[1] < volStopShort[1] ? math.min(newShortStop, volStopShort[1]) : newShortStop

    // FIX: Bias must be EXCLUSIVE (not both true at same time)
    // Use midpoint between stops to determine bias
    float midPoint = (volStopLong + volStopShort) / 2
    bool longBias = close > midPoint
    bool shortBias = close < midPoint  // Mutually exclusive with longBias

    [volStopLong, volStopShort, longBias, shortBias]

// Main context builder
buildMarketContext(int emaFastLen, int emaSlowLen, int atrLen, int atrSmaLen, float atrCompressThresh, float volStopMult) =>
    [trendUp, trendDown, emaFast, emaSlow] = detectTrend(emaFastLen, emaSlowLen)
    [isRanging, atr, atrNorm] = detectRanging(atrLen, atrSmaLen, atrCompressThresh)
    [volStopLong, volStopShort, longBias, shortBias] = calculateVolStop(atr, volStopMult)

    MarketContext.new(trendUp, trendDown, isRanging, volStopLong, volStopShort, longBias, shortBias, atr, atrNorm)

// ============================================================================
// STRENGTH CALCULATION (0-1 scale)
// ============================================================================

// Calculate momentum component (-1 to +1)
calculateMomentumV2(int rsiLen) =>
    float rsi = ta.rsi(close, rsiLen)
    float momScore = (rsi - 50) / 50  // -1 to +1
    momScore

// Calculate trend alignment (0-1)
// ADJUSTED 2025-12: More generous scoring to allow signals in neutral conditions
// Old: 0/0.5/1.0 → New: 0.3/0.6/1.0 (neutral now gives 0.3 instead of 0)
calculateTrendAlign(MarketContext ctx, bool forLong) =>
    if forLong
        ctx.trendUp and ctx.longBias ? 1.0 : ctx.trendUp or ctx.longBias ? 0.6 : 0.3
    else
        ctx.trendDown and ctx.shortBias ? 1.0 : ctx.trendDown or ctx.shortBias ? 0.6 : 0.3

// Calculate zone proximity boost (0-1)
// UPDATED 2025-12: Zone is now OPTIONAL BONUS, not required
// Base boost of 0.5 ensures signals can fire without S/R proximity
// Zone proximity adds extra boost (up to 1.0)
calculateZoneBoost(bool nearSupport, bool nearResistance, float atr) =>
    float BASE_BOOST = 0.5  // Signals can fire without zones
    // Long: Best at support (bounce), ok at resistance (breakout)
    float longBoost = nearSupport ? 1.0 : nearResistance ? 0.8 : BASE_BOOST
    // Short: Best at resistance (rejection), ok at support (breakdown)
    float shortBoost = nearResistance ? 1.0 : nearSupport ? 0.8 : BASE_BOOST
    [longBoost, shortBoost]

// Main strength calculator
// UPDATED 2025-12: Rebalanced weights - less zone dependency
calculateStrength(MarketContext ctx, float momentum, bool nearSupport, bool nearResistance) =>
    // Weights - REBALANCED: Zone now less critical (0.15 instead of 0.25)
    float W_MOM = 0.40    // Increased from 0.35 - momentum more important
    float W_TREND = 0.45  // Increased from 0.40 - trend alignment key
    float W_ZONE = 0.15   // Reduced from 0.25 - zone is bonus, not required

    // Long strength
    float trendAlignLong = calculateTrendAlign(ctx, true)
    [zoneBoostLong, zoneBoostShort] = calculateZoneBoost(nearSupport, nearResistance, ctx.atr)

    float momLong = momentum > 0 ? momentum : 0.0
    float longStrength = (momLong * W_MOM) + (trendAlignLong * W_TREND) + (zoneBoostLong * W_ZONE)

    // Short strength
    float trendAlignShort = calculateTrendAlign(ctx, false)
    float momShort = momentum < 0 ? math.abs(momentum) : 0.0
    float shortStrength = (momShort * W_MOM) + (trendAlignShort * W_TREND) + (zoneBoostShort * W_ZONE)

    StrengthScore.new(longStrength, shortStrength, momentum, (trendAlignLong + trendAlignShort) / 2, (zoneBoostLong + zoneBoostShort) / 2)

// ============================================================================
// ENTRY TYPES (Breakout, Pullback, Continuation)
// ============================================================================

// Breakout entry detection
detectBreakout(MarketContext ctx, int lookback) =>
    float recentHigh = ta.highest(high[1], lookback)
    float recentLow = ta.lowest(low[1], lookback)

    bool breakoutLong = close > recentHigh
    bool breakoutShort = close < recentLow

    [breakoutLong, breakoutShort]

// Pullback entry detection
// Uses JMA instead of EMA for better pullback identification with less lag
detectPullback(MarketContext ctx, float jmaFast, float jmaSlow, bool nearSupport, bool nearResistance) =>
    // Pullback = price pulled back to JMA band + at zone + closes back in trend direction
    // JMA provides smoother pullback zones with fewer false triggers
    bool pullbackLong = nearSupport and low < jmaFast and close > jmaFast and ctx.trendUp
    bool pullbackShort = nearResistance and high > jmaFast and close < jmaFast and ctx.trendDown

    [pullbackLong, pullbackShort]

// Continuation entry detection
detectContinuation(MarketContext ctx, int lookback) =>
    // Mini-pullback + continuation in trend direction
    float recentHigh3 = ta.highest(high[1], 3)
    float recentLow3 = ta.lowest(low[1], 3)

    bool contLong = ctx.longBias and close > recentHigh3
    bool contShort = ctx.shortBias and close < recentLow3

    [contLong, contShort]

