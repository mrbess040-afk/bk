    int totalTFs = mtfScores.totalTFs
    bool hasConsensus = bullishCount >= (totalTFs * 2 / 3) or bearishCount >= (totalTFs * 2 / 3)
    string direction = bullishCount > bearishCount ? "BULLISH" : bearishCount > bullishCount ? "BEARISH" : "NEUTRAL"

    [hasConsensus, direction, bullishCount, bearishCount]

// ===========================================================================
// CONFLUENCE STRENGTH
// ===========================================================================
// Measures how strongly timeframes agree (0-1 scale)

calculateConfluenceStrength(MultiTimeframeScores mtfScores) =>
    // Calculate standard deviation of total scores
    float mean = mtfScores.consensusScore
    float variance = 0.0

    variance += math.pow(mtfScores.tf1.totalScore - mean, 2)
    variance += math.pow(mtfScores.tf2.totalScore - mean, 2)
    variance += math.pow(mtfScores.tf3.totalScore - mean, 2)
    if mtfScores.chartTF.isValid
        variance += math.pow(mtfScores.chartTF.totalScore - mean, 2)

    float stdDev = math.sqrt(variance / mtfScores.totalTFs)

    // Low stdDev = high confluence (scores agree)
    // Normalize: 0.5 stdDev = 0 confluence, 0.0 stdDev = 1.0 confluence
    float confluenceStrength = math.max(0.0, 1.0 - (stdDev / 0.5))
    confluenceStrength

