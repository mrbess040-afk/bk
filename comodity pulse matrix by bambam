calculateMultiTimeframeScores(string tf1, string tf2, string tf3, bool includeChartTF, float flowW, float momW, float trendW, float volW, float structW, float divW) =>

    // SMART TIMEFRAME HIERARCHY: Use hardcoded TFs optimized per chart timeframe
