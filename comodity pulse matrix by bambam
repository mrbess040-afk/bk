        cat2 := mtfScores.tf2.structureScore
        cat3 := mtfScores.tf3.structureScore
        catChart := mtfScores.chartTF.structureScore
    else if category == "divergence"
        cat1 := mtfScores.tf1.divergenceScore
        cat2 := mtfScores.tf2.divergenceScore
        cat3 := mtfScores.tf3.divergenceScore
        catChart := mtfScores.chartTF.divergenceScore

    // Count agreement
    int bullishCount = 0
    int bearishCount = 0

