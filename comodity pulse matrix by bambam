    bool chartIsSmartTF1 = (timeframe.period == smartTF1)
    bool chartIsSmartTF2 = (timeframe.period == smartTF2)
    bool chartIsSmartTF3 = (timeframe.period == smartTF3)
    bool chartTFAlreadyIncluded = chartIsSmartTF1 or chartIsSmartTF2 or chartIsSmartTF3

    // REUSE scores from TF1/TF2/TF3 if Chart TF matches - NO extra request.security() call!
    // FIX: If Chart TF is NOT in Smart TFs, calculate it separately
    TimeframeScores chartScores = chartIsSmartTF1 ? scores1 : chartIsSmartTF2 ? scores2 : chartIsSmartTF3 ? scores3 : calculateTimeframeScores(timeframe.period, flowW, momW, trendW, volW, structW, divW)

    // Only set shouldIncludeChartTF for consensus calculation (not for extra security call)
    bool shouldIncludeChartTF = includeChartTF and not chartTFAlreadyIncluded

    // Calculate consensus
    float sum = scores1.totalScore + scores2.totalScore + scores3.totalScore + (shouldIncludeChartTF ? chartScores.totalScore : 0.0)
    int count = shouldIncludeChartTF ? 4 : 3
    float consensusScore = sum / count

    // Determine dominant direction
    int bullishCount = 0
    int bearishCount = 0

    bullishCount += scores1.totalScore > 0 ? 1 : 0
    bullishCount += scores2.totalScore > 0 ? 1 : 0
    bullishCount += scores3.totalScore > 0 ? 1 : 0
    if shouldIncludeChartTF
        bullishCount += chartScores.totalScore > 0 ? 1 : 0

    bearishCount += scores1.totalScore < 0 ? 1 : 0
    bearishCount += scores2.totalScore < 0 ? 1 : 0
    bearishCount += scores3.totalScore < 0 ? 1 : 0
    if shouldIncludeChartTF
        bearishCount += chartScores.totalScore < 0 ? 1 : 0

    string dominantDirection = bullishCount > bearishCount ? "BULLISH" : bearishCount > bullishCount ? "BEARISH" : "NEUTRAL"

    int alignedCount = math.max(bullishCount, bearishCount)

    // Return multi-timeframe result
    MultiTimeframeScores.new(scores1, scores2, scores3, chartScores, consensusScore, dominantDirection, alignedCount, count)

