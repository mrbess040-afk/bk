// ====================
// DIVERGENCE DETECTION
// ====================

// RSI-Price Divergence Detection
detectRSIDivergences(float rsiVal, int lookbackLeft = 2, int lookbackRight = 2) =>
    // Bullish Divergence: RSI Higher Low + Price Lower Low
    foundPL = not na(ta.pivotlow(rsiVal, lookbackLeft, lookbackRight))

    // Extract ta.valuewhen calls for consistency (bullish)
    prevRSI_bull = ta.valuewhen(foundPL, rsiVal, 1)
    prevLow_bull = ta.valuewhen(foundPL, low, 1)

    bullDiv = false
    bullLevel = 0.0

    if foundPL
        rsiHL = rsiVal > prevRSI_bull       // RSI Higher Low
        priceLL = low < prevLow_bull         // Price Lower Low

        bullDiv := rsiHL and priceLL
        bullLevel := low[lookbackRight]  // Support at divergence low

    // Bearish Divergence: RSI Lower High + Price Higher High
    foundPH = not na(ta.pivothigh(rsiVal, lookbackLeft, lookbackRight))

    // Extract ta.valuewhen calls for consistency (bearish)
    prevRSI_bear = ta.valuewhen(foundPH, rsiVal, 1)
    prevHigh_bear = ta.valuewhen(foundPH, high, 1)

    bearDiv = false
    bearLevel = 0.0

    if foundPH
        rsiLH = rsiVal < prevRSI_bear        // RSI Lower High
        priceHH = high > prevHigh_bear       // Price Higher High

        bearDiv := rsiLH and priceHH
        bearLevel := high[lookbackRight]  // Resistance at divergence high

    [bullDiv, bullLevel, bearDiv, bearLevel, lookbackRight]

// ====================
