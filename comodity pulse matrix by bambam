// Create new divergence zone
createZone(float level, bool isBull, int lookbackRight, color zoneColor) =>
    // Primary line (thin, solid)
    primaryLine = line.new( bar_index - lookbackRight, level, bar_index + 15, level, color = zoneColor, width = 1, style = line.style_solid, extend = extend.none )

    // Background line (thick, transparent)
    bgLine = line.new( bar_index - lookbackRight, level, bar_index + 15, level, color = color.new(zoneColor, 85), width = 3, extend = extend.none )

    // Create zone
    zone = DivergenceZone.new(level, isBull, primaryLine, bgLine, "ACTIVE", bar_index)
    zone

// Update existing zones (extend or mark broken)
updateZones(array<DivergenceZone> zones, int maxSignalAge = 100) =>
    if array.size(zones) > 0
        for i = array.size(zones) - 1 to 0
            zone = array.get(zones, i)
            age = bar_index - zone.creationBar

            // Check if zone is broken
            if zone.isBull
                // Bull zone broken if price goes significantly below
                if close < zone.level * 0.998  // 0.2% below
                    zone.status := "BROKEN"
                    line.set_style(zone.primaryLine, line.style_dashed)
                    line.set_color(zone.primaryLine, color.new(color.gray, 50))
                    if not na(zone.bgLine)
                        line.delete(zone.bgLine)
                        zone.bgLine := na
            else
                // Bear zone broken if price goes significantly above
                if close > zone.level * 1.002  // 0.2% above
                    zone.status := "BROKEN"
                    line.set_style(zone.primaryLine, line.style_dashed)
                    line.set_color(zone.primaryLine, color.new(color.gray, 50))
                    if not na(zone.bgLine)
                        line.delete(zone.bgLine)
                        zone.bgLine := na

            // Extend active zones
            if zone.status == "ACTIVE"
                line.set_x2(zone.primaryLine, bar_index + 15)
                if not na(zone.bgLine)
                    line.set_x2(zone.bgLine, bar_index + 15)

            // Remove broken or too old zones
            if zone.status == "BROKEN" or age > maxSignalAge
                array.remove(zones, i)
                line.delete(zone.primaryLine)
                if not na(zone.bgLine)
                    line.delete(zone.bgLine)

// Cleanup: Limit to MAX zones (FIFO)
cleanupZones(array<DivergenceZone> zones, int maxZones = 5) =>
    while array.size(zones) > maxZones
        expired = array.shift(zones)  // Remove oldest
        line.delete(expired.primaryLine)
        if not na(expired.bgLine)
            line.delete(expired.bgLine)

// ====================
// PROXIMITY CHECK
// ====================

// Check if price is near any active zone
checkProximity(array<DivergenceZone> zones, float currentPrice, float atr, float threshold = 1.0) =>
    isNear = false

    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            zone = array.get(zones, i)

            if zone.status == "ACTIVE"
                distance = math.abs(currentPrice - zone.level) / atr

                if distance < threshold
                    isNear := true
                    break  // One is enough

    isNear

// ====================
// MAIN WORKFLOW
// ====================

// Complete divergence zones workflow
analyzeDivergenceZones( float rsiVal, int lookbackLeft = 2, int lookbackRight = 2, int maxZones = 5, int maxSignalAge = 100, float proximityThreshold = 1.0, color bullColor = color.lime, color bearColor = color.red ) =>

    // Persistent zone arrays
    var array<DivergenceZone> bullZones = array.new<DivergenceZone>()
    var array<DivergenceZone> bearZones = array.new<DivergenceZone>()

    // Detect new divergences
    [bullDiv, bullLevel, bearDiv, bearLevel, lbRight] = detectRSIDivergences(rsiVal, lookbackLeft, lookbackRight)

    // Create new zones
    if bullDiv
        newZone = createZone(bullLevel, true, lbRight, bullColor)
        array.push(bullZones, newZone)

    if bearDiv
        newZone = createZone(bearLevel, false, lbRight, bearColor)
        array.push(bearZones, newZone)

    // Update existing zones
    updateZones(bullZones, maxSignalAge)
    updateZones(bearZones, maxSignalAge)

    // Cleanup (FIFO limit)
    cleanupZones(bullZones, maxZones)
    cleanupZones(bearZones, maxZones)

    // Proximity checks
    atr = ta.atr(14)
    nearBull = checkProximity(bullZones, close, atr, proximityThreshold)
    nearBear = checkProximity(bearZones, close, atr, proximityThreshold)

    // Count active zones
    bullCount = 0
    bearCount = 0

    if array.size(bullZones) > 0
        for i = 0 to array.size(bullZones) - 1
            zone = array.get(bullZones, i)
            if zone.status == "ACTIVE"
                bullCount += 1

    if array.size(bearZones) > 0
        for i = 0 to array.size(bearZones) - 1
            zone = array.get(bearZones, i)
            if zone.status == "ACTIVE"
                bearCount += 1

    // Return result
    result = DivergenceZonesResult.new(bullZones, bearZones, nearBull, nearBear, bullCount, bearCount)
    result


