// CPM v3 - Market Structure Detection
// ============================================================================

// ==== SWING POINT DETECTION ====

// Detect swing high using pivot
// @param leftBars Left bars for pivot detection
// @param rightBars Right bars for pivot detection
// @returns Swing high price or na
detectSwingHigh(int leftBars, int rightBars) =>
    ta.pivothigh(high, leftBars, rightBars)

// Detect swing low using pivot
// @param leftBars Left bars for pivot detection
// @param rightBars Right bars for pivot detection
// @returns Swing low price or na
detectSwingLow(int leftBars, int rightBars) =>
    ta.pivotlow(low, leftBars, rightBars)

// ==== STATE INITIALIZATION ====

// ==== STATE MANAGEMENT ====

// Update structure state with new swing points
// @param state Current structure state
// @param leftBars Left bars for pivot
// @param rightBars Right bars for pivot
// @returns Updated state
updateStructureState(StructureState state, int leftBars, int rightBars) =>
    // Detect new swing points
    float swingHigh = detectSwingHigh(leftBars, rightBars)
    float swingLow = detectSwingLow(leftBars, rightBars)

    // Update swing high if detected
    if not na(swingHigh)
        state.lastSwingHigh := swingHigh
        state.lastSwingHighBar := bar_index - rightBars

    // Update swing low if detected
    if not na(swingLow)
        state.lastSwingLow := swingLow
        state.lastSwingLowBar := bar_index - rightBars

    // Increment bars in current structure
    state.barsInStructure := state.barsInStructure + 1

    // Reset recent flags after a period
    if state.barsInStructure > 5
        state.recentBOS := false
        state.recentCHoCH := false

    state

// ==== BREAK OF STRUCTURE DETECTION ====

// Detect Break of Structure (BOS)
// Price breaking above recent swing high (bullish) or below swing low (bearish)
// @param state Current structure state
// @returns [bosUp, bosDown] tuple
detectBreakOfStructure(StructureState state) =>
    // BOS Up: Close breaks above last swing high
    bool bosUp = close > state.lastSwingHigh

    // BOS Down: Close breaks below last swing low
    bool bosDown = close < state.lastSwingLow

    // Update state if BOS detected
    if bosUp
        state.recentBOS := true
        state.currentStructure := "BULLISH"
        state.barsInStructure := 0

    if bosDown
        state.recentBOS := true
        state.currentStructure := "BEARISH"
        state.barsInStructure := 0

    [bosUp, bosDown]

// ==== CHANGE OF CHARACTER DETECTION ====

// Detect Change of Character (CHoCH)
// Momentum/volatility shift indicating potential trend reversal or consolidation
// @param state Current structure state
// @param atr Current ATR value
// @param atrThreshold ATR threshold multiplier (default 1.5)
// @returns [chochUp, chochDown] tuple
detectChangeOfCharacter(StructureState state, float atr, float atrThreshold = 1.5) =>
    // CHoCH Up: Bearish structure → bullish swing (potential reversal)
    bool wasBearish = state.currentStructure == "BEARISH"
    bool showsBullishSwing = close > state.lastSwingLow + (atr * atrThreshold)
    bool chochUp = wasBearish and showsBullishSwing

    // CHoCH Down: Bullish structure → bearish swing (potential reversal)
    bool wasBullish = state.currentStructure == "BULLISH"
    bool showsBearishSwing = close < state.lastSwingHigh - (atr * atrThreshold)
    bool chochDown = wasBullish and showsBearishSwing

    // Update state if CHoCH detected
    if chochUp
        state.recentCHoCH := true
        state.currentStructure := "CONSOLIDATION"
        state.barsInStructure := 0

    if chochDown
        state.recentCHoCH := true
        state.currentStructure := "CONSOLIDATION"
        state.barsInStructure := 0

    [chochUp, chochDown]

// ==== TREND STRENGTH CALCULATION ====

// Calculate trend strength based on multiple factors
// @param state Structure state
// @param ema20 EMA 20
// @param ema50 EMA 50
// @param ema200 EMA 200
// @param bosUp BOS up flag
// @param bosDown BOS down flag
// @returns Trend strength (0-100)
calculateTrendStrength( StructureState state, float ema20, float ema50, float ema200, bool bosUp, bool bosDown ) =>
    float strength = 0.0
    string structure = state.currentStructure

    // Base strength from structure type
    if structure == "BULLISH" or structure == "BEARISH"
        // Check EMA alignment
        bool bullishAlignment = ema20 > ema50 and ema50 > ema200
        bool bearishAlignment = ema20 < ema50 and ema50 < ema200
        bool hasAlignment = bullishAlignment or bearishAlignment

        // EMA alignment score (0-50)
        float emaScore = hasAlignment ? 50.0 : 25.0

        // BOS bonus (0-25)
        float bosBonus = (bosUp or bosDown) ? 25.0 : 0.0

        // Structure duration bonus (0-25)
        // Longer structure = stronger trend
        float durationBonus = state.barsInStructure > 20 ? 25.0 : state.barsInStructure > 10 ? 15.0 : state.barsInStructure > 5 ? 5.0 : 0.0

        strength := emaScore + bosBonus + durationBonus

    else if structure == "CONSOLIDATION"
        // Low strength in consolidation
        strength := 10.0

    // Recent CHoCH reduces strength (transitioning)
    if state.recentCHoCH
        strength := strength * 0.6

    // Clamp to 0-100
    clamp100(strength)

// ==== MARKET REGIME DETECTION ====

// Detect comprehensive market regime
// @param state Structure state
// @param ema20 EMA 20
// @param ema50 EMA 50
// @param ema200 EMA 200
// @param atr Current ATR
// @param bosUp BOS up flag
// @param bosDown BOS down flag
// @param chochUp CHoCH up flag
// @param chochDown CHoCH down flag
// @returns MarketRegime object
detectMarketRegime( StructureState state, float ema20, float ema50, float ema200, float atr, bool bosUp, bool bosDown, bool chochUp, bool chochDown ) =>
    // Get regime classification from state
    string regimeStr = state.currentStructure

    // Determine regime type flags
    bool trending = (regimeStr == "BULLISH" or regimeStr == "BEARISH")
    bool ranging = (regimeStr == "CONSOLIDATION")
    bool transitioning = state.recentCHoCH

    // Calculate trend strength
    float trendStrength = calculateTrendStrength(state, ema20, ema50, ema200, bosUp, bosDown)

    // Calculate volatility (ATR%)
    float volatility = atrPercent(atr, close)

    // Create and return MarketRegime object
    MarketRegime.new( isTrending = trending, isRanging = ranging, isTransitioning = transitioning, regimeType = regimeStr, trendStrength = trendStrength, volatility = volatility, bosUp = bosUp, bosDown = bosDown, chochUp = chochUp, chochDown = chochDown )

// ==== COMBINED DETECTION WORKFLOW ====

// Full market structure analysis (all-in-one function)
// @param state Structure state (var maintained in main script)
// @param ema20 EMA 20
// @param ema50 EMA 50
// @param ema200 EMA 200
// @param atr Current ATR
// @param leftBars Pivot left bars (default 5)
// @param rightBars Pivot right bars (default 5)
// @param chochThreshold CHoCH ATR threshold (default 1.5)
// @returns MarketRegime object
analyzeMarketStructure( StructureState state, float ema20, float ema50, float ema200, float atr, int leftBars = 5, int rightBars = 5, float chochThreshold = 1.5 ) =>
    // Step 1: Update state with new swing points
    updateStructureState(state, leftBars, rightBars)

    // Step 2: Detect BOS
    [bosUp, bosDown] = detectBreakOfStructure(state)

    // Step 3: Detect CHoCH
    [chochUp, chochDown] = detectChangeOfCharacter(state, atr, chochThreshold)

    // Step 4: Build comprehensive regime
    detectMarketRegime(state, ema20, ema50, ema200, atr, bosUp, bosDown, chochUp, chochDown)

// ==== HELPER FUNCTIONS ====

// Get human-readable market structure string for display
// @param regime Market regime
// @returns Formatted string with BOS/CHoCH indicators
getMarketStructureString(MarketRegime regime) =>
    string structure = regime.regimeType

    // Add BOS indicators
    if regime.bosUp
        structure := structure + " (BOS↑)"
    else if regime.bosDown
        structure := structure + " (BOS↓)"

    // Add CHoCH indicators
    if regime.chochUp
        structure := structure + " CHoCH↑"
    else if regime.chochDown
        structure := structure + " CHoCH↓"

    structure

// Get regime color for visualization
// @param regime Market regime
// @returns Color based on regime type
getRegimeColor(MarketRegime regime) =>
    switch regime.regimeType
        "BULLISH" => color.new(color.green, regime.isTransitioning ? 50 : 0)
        "BEARISH" => color.new(color.red, regime.isTransitioning ? 50 : 0)
        "CONSOLIDATION" => color.new(color.gray, 20)
        => color.new(color.yellow, 0)

// Get trend strength grade
// @param trendStrength Trend strength (0-100)
// @returns Grade string
getTrendStrengthGrade(float trendStrength) =>
    switch
        trendStrength >= 75 => "VERY STRONG"
        trendStrength >= 50 => "STRONG"
        trendStrength >= 25 => "MODERATE"
        => "WEAK"

// Check if market structure is bullish
// @param regime Market regime
// @returns True if bullish structure
isBullishStructure(MarketRegime regime) =>
    regime.regimeType == "BULLISH" and regime.isTrending

// Check if market structure is bearish
// @param regime Market regime
// @returns True if bearish structure
isBearishStructure(MarketRegime regime) =>
    regime.regimeType == "BEARISH" and regime.isTrending

// Check if market is consolidating
// @param regime Market regime
// @returns True if consolidating
isConsolidating(MarketRegime regime) =>
    regime.isRanging or regime.isTransitioning

// Check if regime is favorable for trading
// @param regime Market regime
// @param minTrendStrength Minimum trend strength required
// @returns True if favorable
isFavorableRegime(MarketRegime regime, float minTrendStrength = 50.0) =>
    regime.isTrending and regime.trendStrength >= minTrendStrength and not regime.isTransitioning

// ==== SWING DISTANCE UTILITIES ====

// Calculate distance to last swing high
// @param state Structure state
// @returns Distance in price points
distanceToSwingHigh(StructureState state) =>
    state.lastSwingHigh - close

// Calculate distance to last swing low
// @param state Structure state
// @returns Distance in price points
distanceToSwingLow(StructureState state) =>
    close - state.lastSwingLow

// Calculate distance to nearest swing point
// @param state Structure state
// @returns Distance to nearest swing
distanceToNearestSwing(StructureState state) =>
    float distHigh = math.abs(distanceToSwingHigh(state))
    float distLow = math.abs(distanceToSwingLow(state))
    math.min(distHigh, distLow)

// Calculate bars since last swing high
// @param state Structure state
// @returns Bars since last swing high
barsSinceSwingHigh(StructureState state) =>
    bar_index - state.lastSwingHighBar

// Calculate bars since last swing low
// @param state Structure state
// @returns Bars since last swing low
barsSinceSwingLow(StructureState state) =>
    bar_index - state.lastSwingLowBar

// ==== STRUCTURE QUALITY ASSESSMENT ====

// Assess quality of market structure for trading
// @param regime Market regime
// @param state Structure state
// @returns Quality score (0-100)
assessStructureQuality(MarketRegime regime, StructureState state) =>
    float quality = 50.0

    // Trending regime bonus
    if regime.isTrending
        quality += 20.0

    // Trend strength bonus
    quality += (regime.trendStrength / 100.0) * 20.0

    // Recent BOS bonus (confirming structure)
    if state.recentBOS and state.barsInStructure < 10
        quality += 10.0

    // Penalty for transitioning
    if regime.isTransitioning
        quality -= 20.0

    // Penalty for high volatility
    if regime.volatility > 3.0
        quality -= 15.0

    // Penalty for very low volatility
    if regime.volatility < 0.5
        quality -= 10.0

    // Clamp and return
    clamp100(quality)


