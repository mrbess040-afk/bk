// ============================================================================
// DENSITY THRESHOLDS
// ============================================================================

// Map density setting to thresholds
// ADJUSTED 2025-12: Reduced by ~25% to generate more signals
// Old values were too restrictive (rarely reached 0.55+ strength)
getDensityThresholdsV2(string density) =>
    float bpcThresh = switch density
        "Few (Top Signals)"        => 0.50  // was 0.65
        "Moderate"                 => 0.35  // was 0.45
        "Many (Scalper)"           => 0.20  // was 0.30
        => 0.35

    float finalThresh = switch density
        "Few (Top Signals)"        => 0.60  // was 0.75
        "Moderate"                 => 0.45  // was 0.55
        "Many (Scalper)"           => 0.30  // was 0.40
        => 0.45

    [bpcThresh, finalThresh]

// ============================================================================
// MAIN ENTRY ENGINE
// ============================================================================

// Generate entry signals (two levels: bpc + final)
// Now uses JMA (Jurik Moving Average) instead of EMA for reduced lag
// UPDATED 2025-12: Added customThreshold parameter for configurable strength threshold
// customThreshold: 0 = use density defaults, >0 = override final threshold
generateEntries( string density, MarketContext ctx, StrengthScore strength, bool nearSupport, bool nearResistance, bool enableBreakout, bool enablePullback, bool enableContinuation, bool allowCounterTrend, int lookback, float jmaFast, float jmaSlow, float customThreshold = 0.0 ) =>
    // Safe momentum (NaN guard)
    float momentumVal = nz(strength.momentum, 0.0)

    [bpcThresh, defaultFinalThresh] = getDensityThresholdsV2(density)
    // Use custom threshold if provided, otherwise use density default
    float finalThresh = customThreshold > 0 ? customThreshold : defaultFinalThresh

    // Detect entry types
    [breakoutLong, breakoutShort] = detectBreakout(ctx, lookback)
    [pullbackLong, pullbackShort] = detectPullback(ctx, jmaFast, jmaSlow, nearSupport, nearResistance)
    [contLong, contShort] = detectContinuation(ctx, lookback)

    // === RANGING MARKET FILTER ===
    // In ranging markets (low volatility/ATR compression):
    // - Breakouts are often fakeouts → disable
    // - Continuations have no trend to continue → disable
    // - Pullbacks are still valid (mean reversion plays)
    bool allowBreakoutInMarket = enableBreakout and not ctx.isRanging
    bool allowContinuationInMarket = enableContinuation and not ctx.isRanging

    // Combine enabled types (with ranging filter applied)
    bool rawLong = (allowBreakoutInMarket and breakoutLong) or (enablePullback and pullbackLong) or (allowContinuationInMarket and contLong)
    bool rawShort = (allowBreakoutInMarket and breakoutShort) or (enablePullback and pullbackShort) or (allowContinuationInMarket and contShort)

    // Check counter-trend
    bool isCounterTrendLong = rawLong and ctx.shortBias
    bool isCounterTrendShort = rawShort and ctx.longBias

    // Counter-trend requires slightly higher threshold (reduced from 1.3)
    float ctMult = 1.15
    float longThreshBpc = isCounterTrendLong ? bpcThresh * ctMult : bpcThresh
    float longThreshFinal = isCounterTrendLong ? finalThresh * ctMult : finalThresh
    float shortThreshBpc = isCounterTrendShort ? bpcThresh * ctMult : bpcThresh
    float shortThreshFinal = isCounterTrendShort ? finalThresh * ctMult : finalThresh

    // === S/R THRESHOLD RELAXATION (LOCAL ONLY) ===
    // Allow slightly easier triggers when close to support/resistance, without spamming elsewhere
    float srBonusBpc = 0.10   // For BPC level (easier near S/R)
    float srBonusFinal = 0.15 // Stronger relaxation on final level near S/R
    if nearSupport
        longThreshBpc := math.max(0.0, longThreshBpc - srBonusBpc)
        longThreshFinal := math.max(0.0, longThreshFinal - srBonusFinal)
    if nearResistance
        shortThreshBpc := math.max(0.0, shortThreshBpc - srBonusBpc)
        shortThreshFinal := math.max(0.0, shortThreshFinal - srBonusFinal)

    // === MOMENTUM DIRECTION VALIDATION ===
    // LONG signals require non-negative momentum (at least neutral)
    // SHORT signals require non-positive momentum (at least neutral)
    // Small tolerance (-0.05 to +0.05) allows neutral conditions
    // At S/R we disable the hard momentum filter to allow signals that rely on zone context
    bool srContext = nearSupport or nearResistance
    float momTol = srContext ? 1e9 : 0.05  // effectively no momentum gating at S/R
    bool momSupportsLong = srContext or momentumVal >= -momTol   // Momentum at least neutral for LONG
    bool momSupportsShort = srContext or momentumVal <= momTol   // Momentum at least neutral for SHORT

    // Apply thresholds + momentum direction check
    bool bpcLong = rawLong and strength.longStrength >= longThreshBpc and (allowCounterTrend or not isCounterTrendLong) and momSupportsLong
    bool bpcShort = rawShort and strength.shortStrength >= shortThreshBpc and (allowCounterTrend or not isCounterTrendShort) and momSupportsShort

    bool finalLong = rawLong and strength.longStrength >= longThreshFinal and (allowCounterTrend or not isCounterTrendLong) and momSupportsLong
    bool finalShort = rawShort and strength.shortStrength >= shortThreshFinal and (allowCounterTrend or not isCounterTrendShort) and momSupportsShort

    // Determine entry type
    string entryType = breakoutLong or breakoutShort ? "BREAKOUT" : pullbackLong or pullbackShort ? "PULLBACK" : contLong or contShort ? "CONTINUATION" : "NONE"

    EntrySignal.new( bpcLong, bpcShort, strength.longStrength, strength.shortStrength, finalLong, finalShort, strength.longStrength, strength.shortStrength, entryType, isCounterTrendLong or isCounterTrendShort )


// ============================================================================
// CPM v3 - Entry State Machine
// ============================================================================

// ============================================================================
// TYPES
// ============================================================================

type EntryState
    int direction           // -1 (short), 0 (neutral), +1 (long)
    float strength          // Strength at phase start
    int lastEntryBar        // Bar index of last entry event
    int lastWarnBar         // Bar index of last warning event
    string lastEventType    // "FIRST", "UPGRADE", "NONE"

type EntryEvent
    bool emitEntry          // Should emit entry signal
    bool emitWarning        // Should emit warning signal
    string eventType        // "FIRST", "UPGRADE", "NONE"
    int direction           // Current direction
    float strength          // Current strength
    bool isUpgrade          // True if this is an upgrade event

// ============================================================================
// STATE MACHINE LOGIC
// ============================================================================

// Initialize new state
newEntryState() =>
    EntryState.new(0, na, na, na, "NONE")

// Check if entry can be emitted (cooldown)
canEmitEntry(EntryState state, int cooldownBars) =>
    na(state.lastEntryBar) or (bar_index - state.lastEntryBar) >= cooldownBars

// Check if warning can be emitted (separate cooldown)
canEmitWarning(EntryState state, int cooldownBars) =>
    na(state.lastWarnBar) or (bar_index - state.lastWarnBar) >= cooldownBars

// Check if strength upgrade is significant
isSignificantUpgrade(float newStrength, float oldStrength, float upgradeDelta) =>
    not na(oldStrength) and (newStrength - oldStrength) >= upgradeDelta

// Process entry signals and return event
processEntry( EntryState state, bool finalLong, bool finalShort, float longStrength, float shortStrength, int entryCooldown, float upgradeDelta ) =>
    // Determine new direction
    int newDir = finalLong ? 1 : finalShort ? -1 : 0
    float newStrength = finalLong ? longStrength : finalShort ? shortStrength : 0.0

    // === DIRECTIONAL COOLDOWN ===
    // Cooldown only applies to SAME direction signals
    // Direction changes (reversals) are always allowed immediately
    bool isDirectionChange = newDir != state.direction and newDir != 0
    bool isSameDirection = newDir == state.direction and newDir != 0

    // Only check cooldown for same-direction signals
    bool cooldownPassed = canEmitEntry(state, entryCooldown)
    bool canEmit = isDirectionChange or (isSameDirection and cooldownPassed)

    // Detect event type
    bool isFirst = isDirectionChange and canEmit
    bool isUpgrade = isSameDirection and canEmit and isSignificantUpgrade(newStrength, state.strength, upgradeDelta)

    bool emitEntry = isFirst or isUpgrade
    string eventType = isFirst ? "FIRST" : isUpgrade ? "UPGRADE" : "NONE"

    // Build event
    EntryEvent event = EntryEvent.new(emitEntry, false, eventType, newDir, newStrength, isUpgrade)

    // Update state
    EntryState newState = state
    if emitEntry
        newState := EntryState.new(newDir, newStrength, bar_index, state.lastWarnBar, eventType)

    [event, newState]

// Process warnings
processWarning( EntryState state, bool warningBull, bool warningBear, int warnCooldown ) =>
    bool canEmit = canEmitWarning(state, warnCooldown)
    bool emitWarning = (warningBull or warningBear) and canEmit

    // Update state
    EntryState newState = state
    if emitWarning
        newState := EntryState.new(state.direction, state.strength, state.lastEntryBar, bar_index, state.lastEventType)

    [emitWarning, newState]

// ============================================================================
// MAIN UPDATE FUNCTION
// ============================================================================

// Update state machine with new signals
updateEntryStateMachine( EntryState state, bool finalLong, bool finalShort, float longStrength, float shortStrength, bool warningBull, bool warningBear, int entryCooldown, int warnCooldown, float upgradeDelta ) =>
    // Process entries
    [entryEvent, stateAfterEntry] = processEntry(state, finalLong, finalShort, longStrength, shortStrength, entryCooldown, upgradeDelta)

    // Process warnings (using updated state)
    [emitWarning, finalState] = processWarning(stateAfterEntry, warningBull, warningBear, warnCooldown)

    // Merge events
    EntryEvent finalEvent = EntryEvent.new( entryEvent.emitEntry, emitWarning, entryEvent.eventType, entryEvent.direction, entryEvent.strength, entryEvent.isUpgrade )

    [finalEvent, finalState]


