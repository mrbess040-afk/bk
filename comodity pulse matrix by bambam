const float MATRIX_NEUTRAL_DEADZONE = 0.10

getCellColor(float score, bool isHeader = false) =>
    if isHeader
        color.new(#1976D2, 0)  // Blue for headers
    else if math.abs(score) < MATRIX_NEUTRAL_DEADZONE
        color.new(#616161, 0)  // Neutral - Dark Gray for contrast
    else if score > 2.5
        color.new(#00E676, 0)  // Very Strong Bullish - Bright Green
    else if score > 1.5
        color.new(#4CAF50, 0)  // Strong Bullish - Green
    else if score > 0.5
        color.new(#81C784, 0)  // Moderate Bullish - Medium Green
    else if score >= MATRIX_NEUTRAL_DEADZONE
        color.new(#66BB6A, 0)  // Weak Bullish - Darker Green for readability
    else if score < -2.5
        color.new(#FF1744, 0)  // Very Strong Bearish - Bright Red
    else if score < -1.5
        color.new(#F44336, 0)  // Strong Bearish - Red
    else if score < -0.5
        color.new(#E57373, 0)  // Moderate Bearish - Medium Red
    else if score <= -MATRIX_NEUTRAL_DEADZONE
        color.new(#EF5350, 0)  // Weak Bearish - Darker Red for readability
    else
        color.new(#616161, 0)  // Neutral - Dark Gray for contrast

getScoreSymbol(float score) =>
    if math.abs(score) < MATRIX_NEUTRAL_DEADZONE
        "○"   // Neutral
    else if score > 2.5
        "▲▲"  // Very strong up
    else if score > 1.5
        "▲"   // Strong up
    else if score > 0.5
        "△"   // Moderate up
    else if score >= MATRIX_NEUTRAL_DEADZONE
        "·"   // Weak up
    else if score < -2.5
        "▼▼"  // Very strong down
    else if score < -1.5
        "▼"   // Strong down
    else if score < -0.5
        "▽"   // Moderate down
    else if score <= -MATRIX_NEUTRAL_DEADZONE
        "·"   // Weak down
    else
        "○"   // Neutral

