// This ensures state persists across bars within the same function context

// ===========================================================================
// STRATEGY A: BALANCED
// ===========================================================================
// Requirements:
// - Flow + Momentum MUST agree (Confluence Gate)
// - At least 1 Structure Confirmation (Zone/Exhaustion/MV)
// - Chart TF primary (60%) + HTF validation (40%)
// - Strong: High precision score + HTF aligned
// - Moderate: Medium precision score + structure confirmed

strategyA(MultiTimeframeScores mtfScores, DiamondZoneResult zones, ExhaustionResult exhaust, MVInterpretation mvInterp, MarketRegime regime, float strongThresh = 0.40, float moderateThresh = 0.25) =>

    // Chart TF scores (primary signal source)
    TimeframeScores chartTF = mtfScores.chartTF
    float flowScore = chartTF.flowScore
    float momScore = chartTF.momentumScore
    float trendScore = chartTF.trendScore

    // CONFLUENCE: Use combined score direction (weighted average decides)
    // Momentum weighted HIGHER because it's more reliable for reversals
    float combinedScore = (flowScore * 0.35) + (momScore * 0.50) + (trendScore * 0.15)
    bool bullishConfluence = combinedScore > 0.03  // Slight positive bias required
    bool bearishConfluence = combinedScore < -0.03  // Slight negative bias required

    // STRUCTURE CONFIRMATION: At least 1 must be true
    bool hasStructure = (zones.atSupport or zones.atResistance or zones.nearSupport or zones.nearResistance) or (exhaust.bullWatch or exhaust.bearWatch or exhaust.bullConfirmed or exhaust.bearConfirmed) or mvInterp.volumeConfirmed

    // HTF VALIDATION: Average of TF1 + TF2 (guard against na)
    float tf1Total = nz(mtfScores.tf1.totalScore, 0.0)
    float tf2Total = nz(mtfScores.tf2.totalScore, 0.0)
    float htfScore = (tf1Total + tf2Total) / 2.0
    bool htfAligned = (htfScore > 0 and bullishConfluence) or (htfScore < 0 and bearishConfluence)

    // PRECISION SCORE: Chart 60% + HTF 40%
    float chartScore = (flowScore * 0.50) + (momScore * 0.40) + (trendScore * 0.10)
    float precisionScore = (chartScore * 0.60) + (htfScore * 0.40)

    // ADAPTIVE THRESHOLDS (regime-aware)
    float regimeAdjust = regime.isTrending ? 0.85 : regime.isRanging ? 1.20 : 1.0
    float adjStrongThresh = strongThresh * regimeAdjust
    float adjModerateThresh = moderateThresh * regimeAdjust

    // GENERATE SIGNALS
    // Strong: Score threshold + confluence + (structure OR htf)
    bool strongBuy = precisionScore >= adjStrongThresh and bullishConfluence and (hasStructure or htfAligned)
    bool strongSell = precisionScore <= -adjStrongThresh and bearishConfluence and (hasStructure or htfAligned)

    // Moderate: Score threshold + confluence + (structure OR htf) - STRICTER than before
    // This prevents early/weak signals without any confirmation
    bool moderateBuy = not strongBuy and precisionScore >= adjModerateThresh and bullishConfluence and (hasStructure or htfAligned)
    bool moderateSell = not strongSell and precisionScore <= -adjModerateThresh and bearishConfluence and (hasStructure or htfAligned)

    [strongBuy, strongSell, moderateBuy, moderateSell]

// ===========================================================================
// ZONE-BIASED THRESHOLD ADJUSTMENT
// ===========================================================================
// Reduces thresholds when price is near support/resistance

adjustThresholdsForZones(float strongThresh, float moderateThresh, DiamondZoneResult zones, float maxAdjustment = 0.3) =>

    float adjustment = math.abs(zones.signalBoost)  // Use magnitude only

    // Reduce thresholds when at zones (easier to signal)
    float adjustedStrong = strongThresh - adjustment
    float adjustedModerate = moderateThresh - adjustment

    // Clamp to minimum values (prevent negative thresholds)
    adjustedStrong := math.max(0.01, adjustedStrong)
    adjustedModerate := math.max(0.005, adjustedModerate)

    [adjustedStrong, adjustedModerate]

// ===========================================================================
// CONFIDENCE CALCULATION
// ===========================================================================

calculateSignalConfidence(MultiTimeframeScores mtfScores, HeatScoreBreakdown heatBreakdown, MVInterpretation mvInterp, ExhaustionResult exhaust) =>

    float confidence = 0.0

    // MTF Alignment (30%)
    float alignmentScore = float(mtfScores.alignedCount) / float(mtfScores.totalTFs)
    confidence += alignmentScore * 0.30

    // Heat Score (25%)
    confidence += heatBreakdown.overall * 0.25

    // MV Confluence (20%)
    float mvScore = math.abs(mvInterp.score)
    confidence += mvScore * 0.20

    // Score Magnitude (15%)
    float scoreMag = math.min(1.0, math.abs(mtfScores.consensusScore) / 2.0)
    confidence += scoreMag * 0.15

    // Exhaustion Confirmation (10%)
    float exhScore = math.abs(getExhaustionScore(exhaust))
    confidence += exhScore * 0.10

    // Classify confidence level (tighter thresholds for clearer distinction)
    string confidenceLevel = confidence >= 0.65 ? "HIGH" : confidence >= 0.45 ? "MEDIUM" : "LOW"

    [confidence, confidenceLevel]

// ===========================================================================
// MAIN SIGNAL GENERATION
// ===========================================================================

generateSignals(MultiTimeframeScores mtfScores, DiamondZoneResult zones, HeatScoreBreakdown heatBreakdown, MVInterpretation mvInterp, ExhaustionResult exhaust, MarketRegime regime, float strongThresh = 1.5, float moderateThresh = 1.0, bool useZoneBias = true, bool useHeatFilter = true, float minHeat = 0.3) =>

    // Adjust thresholds for zones if enabled
    float adjustedStrong = strongThresh
    float adjustedModerate = moderateThresh
    if useZoneBias
        [zoneStrong, zoneModerate] = adjustThresholdsForZones(strongThresh, moderateThresh, zones)
        adjustedStrong := zoneStrong
        adjustedModerate := zoneModerate

    // Generate base signals via Strategy A (Balanced)
    [sb, ss, mb, ms] = strategyA(mtfScores, zones, exhaust, mvInterp, regime, adjustedStrong, adjustedModerate)
    bool strongBuy = sb
    bool strongSell = ss
    bool moderateBuy = mb
    bool moderateSell = ms

    // Calculate confidence
    [confidence, confidenceLevel] = calculateSignalConfidence(mtfScores, heatBreakdown, mvInterp, exhaust)

    // Apply filters (exhFilter and mvFilter REMOVED - redundant with Strategy hasStructure)
    bool passedHeatFilter = not useHeatFilter or heatBreakdown.overall >= minHeat

    // Apply all filters (now only Heat)
    bool allFiltersPassed = passedHeatFilter

    // Final signals (only if filters pass)
    strongBuy := strongBuy and allFiltersPassed
    strongSell := strongSell and allFiltersPassed
    moderateBuy := moderateBuy and allFiltersPassed
    moderateSell := moderateSell and allFiltersPassed

    // === CONFIDENCE-BASED QUALITY GATE ===
    // Strong signals require HIGH confidence, otherwise downgrade to moderate
    float strongConfMin = 0.65    // stricter for strong signals
    float moderateConfMin = 0.45  // filter weak setups

    // Downgrade Strong → Moderate if confidence too low
    if (strongBuy or strongSell) and confidence < strongConfMin
        if strongBuy
            moderateBuy := true
        if strongSell
            moderateSell := true
        strongBuy := false
        strongSell := false

    // Remove Moderate signals if confidence too low
    if (moderateBuy or moderateSell) and confidence < moderateConfMin
        moderateBuy := false
        moderateSell := false

    // === MTF ALIGNMENT GATE ===
    // REMOVED: Each strategy already handles MTF logic internally

    // === COOLDOWN ===
    // NOTE: Cooldown is now applied in MAIN SCRIPT after generateSignals()
    // Pine Script var in functions doesn't share state properly
    // Cooldown logic moved to commodity_pulse_matrix_v3.pine

    // Determine signal reason
    string reason = ""
    if strongBuy
        reason := "Strong Buy: Score " + str.tostring(mtfScores.consensusScore, "#.00")
    else if strongSell
        reason := "Strong Sell: Score " + str.tostring(mtfScores.consensusScore, "#.00")
    else if moderateBuy
        reason := "Moderate Buy: Score " + str.tostring(mtfScores.consensusScore, "#.00")
    else if moderateSell
        reason := "Moderate Sell: Score " + str.tostring(mtfScores.consensusScore, "#.00")

    // Return result (cooldown fields set to defaults - applied in main script)
    SignalResult.new(strongBuy, strongSell, moderateBuy, moderateSell, mtfScores.consensusScore, reason, confidence, confidenceLevel, passedHeatFilter, false, 0)

