// ==== PIVOT DETECTION ====

detectPivotHigh(int leftBars = 5, int rightBars = 5) =>
    bool isPivot = true
    float pivotPrice = high[rightBars]

    // Check left side
    for i = 0 to leftBars - 1
        if high[rightBars + i + 1] > pivotPrice
            isPivot := false
            break

    // Check right side
    if isPivot
        for i = 0 to rightBars - 1
            if high[i] > pivotPrice
                isPivot := false
                break

    [isPivot, pivotPrice]

detectPivotLow(int leftBars = 5, int rightBars = 5) =>
    bool isPivot = true
    float pivotPrice = low[rightBars]

    // Check left side
    for i = 0 to leftBars - 1
        if low[rightBars + i + 1] < pivotPrice
            isPivot := false
            break

    // Check right side
    if isPivot
        for i = 0 to rightBars - 1
            if low[i] < pivotPrice
                isPivot := false
                break

    [isPivot, pivotPrice]

// ===========================================================================
// DIAMOND ZONE CREATION
// ===========================================================================

createDiamondZone(float pivotPrice, bool isSupport, float atr, float atrMultiplier = 0.3) =>
    // Calculate zone boundaries with ATR padding
    float zonePadding = atr * atrMultiplier
    float upper = pivotPrice + zonePadding
    float lower = pivotPrice - zonePadding

    DiamondZone.new(pivotPrice, upper, lower, isSupport, 0, true, false, 0, 1.0)

// ===========================================================================
// ZONE VALIDATION & AGING
// ===========================================================================

updateZoneAge(DiamondZone zone) =>
    if not na(zone)
        zone.barsAgo := zone.barsAgo + 1

        // Decay strength over time (max 100 bars)
        float ageFactor = math.max(0.5, 1.0 - (zone.barsAgo / 100.0))
        zone.strength := zone.strength * ageFactor
    zone

checkZoneBroken(DiamondZone zone, float closePrice) =>
    if not na(zone) and zone.isValid
        // Support broken if price closes below lower boundary
        if zone.isSupport and closePrice < zone.lower
            zone.isValid := false

        // Resistance broken if price closes above upper boundary
        if not zone.isSupport and closePrice > zone.upper
            zone.isValid := false
    zone

checkZoneTested(DiamondZone zone, float closePrice, float barHigh, float barLow) =>
    if not na(zone) and zone.isValid
        bool tested = false

        if zone.isSupport
            // Support tested if price wicks into zone
            tested := barLow <= zone.upper and barLow >= zone.lower
        else
            // Resistance tested if price wicks into zone
            tested := barHigh >= zone.lower and barHigh <= zone.upper

        if tested
            zone.isTested := true
            zone.testCount := zone.testCount + 1
            // Increase strength on successful test
            zone.strength := math.min(1.0, zone.strength + 0.1)
    zone

// ===========================================================================
// ZONE PROXIMITY DETECTION
// ===========================================================================

checkPriceNearZone(float closePrice, DiamondZone zone, float proximityThreshold = 0.01) =>
    if na(zone) or not zone.isValid
        [false, false]
    else
        // Calculate distance to zone center
        float distancePct = math.abs(closePrice - zone.level) / zone.level

        // Near = within proximity threshold (e.g., 1% of zone level)
        bool isNear = distancePct <= proximityThreshold

        // Inside = price within zone boundaries
        bool isInside = closePrice >= zone.lower and closePrice <= zone.upper

        [isNear, isInside]

// ===========================================================================
// MAIN DIAMOND ZONE DETECTION
// ===========================================================================

detectDiamondZones(int pivotLeftBars = 5, int pivotRightBars = 5, int atrLen = 14, float atrMultiplier = 0.3, float proximityThreshold = 0.01) =>

    // Calculate ATR for zone padding
    float atr = ta.atr(atrLen)

    // Detect pivots
    [isPivotHigh, pivotHighPrice] = detectPivotHigh(pivotLeftBars, pivotRightBars)
    [isPivotLow, pivotLowPrice] = detectPivotLow(pivotLeftBars, pivotRightBars)

    // Track zones using var (persistent across bars)
    var DiamondZone supportZone = na
    var DiamondZone resistanceZone = na

    // Update existing zones
    if not na(supportZone)
        supportZone := updateZoneAge(supportZone)
        supportZone := checkZoneBroken(supportZone, close)
        supportZone := checkZoneTested(supportZone, close, high, low)

    if not na(resistanceZone)
        resistanceZone := updateZoneAge(resistanceZone)
        resistanceZone := checkZoneBroken(resistanceZone, close)
        resistanceZone := checkZoneTested(resistanceZone, close, high, low)

    // Create new zones on pivot detection
    if isPivotLow
        supportZone := createDiamondZone(pivotLowPrice, true, atr, atrMultiplier)

    if isPivotHigh
        resistanceZone := createDiamondZone(pivotHighPrice, false, atr, atrMultiplier)

    // Check proximity to zones
    [nearSupport, atSupport] = checkPriceNearZone(close, supportZone, proximityThreshold)
    [nearResistance, atResistance] = checkPriceNearZone(close, resistanceZone, proximityThreshold)

    // Calculate signal boost based on zone proximity
    float signalBoost = 0.0

    // Bullish boost at support zone
    if atSupport and not na(supportZone) and supportZone.isValid
        signalBoost := 0.3 * supportZone.strength  // Max +0.3
    else if nearSupport and not na(supportZone) and supportZone.isValid
        signalBoost := 0.15 * supportZone.strength  // Max +0.15

    // Bearish boost at resistance zone
    if atResistance and not na(resistanceZone) and resistanceZone.isValid
        signalBoost := -0.3 * resistanceZone.strength  // Max -0.3
    else if nearResistance and not na(resistanceZone) and resistanceZone.isValid
        signalBoost := -0.15 * resistanceZone.strength  // Max -0.15

    // Return result
    DiamondZoneResult.new(supportZone, resistanceZone, nearSupport, nearResistance, atSupport, atResistance, signalBoost)

// ===========================================================================
// DIAMOND ZONE WITH CONFLUENCE
// ===========================================================================
// Enhanced version with divergence/exhaustion gating

detectDiamondZonesWithConfluence(int pivotLeftBars = 5, int pivotRightBars = 5, int atrLen = 14, float atrMultiplier = 0.3, float proximityThreshold = 0.01, bool hasBullishDivergence = false, bool hasBearishDivergence = false, bool hasBullishExhaustion = false, bool hasBearishExhaustion = false) =>

    // Get base zones
    DiamondZoneResult result = detectDiamondZones(pivotLeftBars, pivotRightBars, atrLen,
                                                   atrMultiplier, proximityThreshold)

    // Apply confluence boost
    float confluenceBoost = 0.0

    // Bullish confluence at support
    if result.atSupport or result.nearSupport
        if hasBullishDivergence
            confluenceBoost += 0.15
        if hasBullishExhaustion
            confluenceBoost += 0.15

    // Bearish confluence at resistance
    if result.atResistance or result.nearResistance
        if hasBearishDivergence
            confluenceBoost -= 0.15
        if hasBearishExhaustion
            confluenceBoost -= 0.15

    // Add confluence boost to base signal boost
    result.signalBoost := result.signalBoost + confluenceBoost

    // Clamp to reasonable range
    result.signalBoost := math.max(-0.5, math.min(0.5, result.signalBoost))

    result

